#!/usr/bin/env bash
# bin/redeploy — single-command iteration loop for the production deployment
# at ideal-magic.com.
#
# What it does, in order:
#   1. git pull (fast-forward only)
#   2. bundle install (production groups only)
#   3. db:prepare (creates/migrates primary, cache, queue, cable)
#   4. assets:precompile
#   5. systemctl restart ideal-magic-web (zero-downtime via Puma phased restart
#      would be possible later; restart is fine for active development)
#   6. /up health check against the live domain
#
# Requires:
#   - Run as user `sawyer`.
#   - /etc/ideal-magic-web/env exists (env file used by the systemd unit).
#   - Sudo password is read from $SUDO_PASS or interactively (one prompt).
set -euo pipefail

APP_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$APP_ROOT"

export PATH="/home/sawyer/.local/share/mise/installs/ruby/4.0.3/bin:/home/sawyer/.local/share/mise/installs/node/24.13.1/bin:$PATH"
export BUNDLE_GEMFILE="$APP_ROOT/Gemfile"
export RAILS_ENV=production
# Pull DB password and other secrets from the systemd env file.
set -a
# shellcheck disable=SC1091
. /etc/ideal-magic-web/env
set +a

echo "==> [1/6] git pull --ff-only"
if [ -d .git ]; then
  git pull --ff-only || echo "(skip: pull failed; continuing with local tree)"
else
  echo "(skip: not a git working tree)"
fi

echo "==> [2/6] bundle install (without development:test)"
bundle config set --local without 'development:test' >/dev/null
bundle check >/dev/null 2>&1 || bundle install

echo "==> [3/6] rails db:prepare"
bundle exec rails db:prepare

echo "==> [4/6] rails assets:precompile"
SECRET_KEY_BASE_DUMMY=1 bundle exec rails assets:precompile

echo "==> [5/6] systemctl restart ideal-magic-web"
if [ -n "${SUDO_PASS:-}" ]; then
  echo "$SUDO_PASS" | sudo -S -p '' systemctl restart ideal-magic-web.service
else
  sudo systemctl restart ideal-magic-web.service
fi

echo "==> [6/6] health check"
sleep 3
for i in 1 2 3 4 5; do
  code=$(curl -s -o /dev/null -w "%{http_code}" https://ideal-magic.com/up || true)
  if [ "$code" = "200" ]; then
    echo "    https://ideal-magic.com/up -> 200 OK"
    echo "==> redeploy complete"
    exit 0
  fi
  echo "    attempt $i: /up returned $code, retrying..."
  sleep 2
done

echo "!! /up did not return 200 after retries. Recent service logs:" >&2
if [ -n "${SUDO_PASS:-}" ]; then
  echo "$SUDO_PASS" | sudo -S -p '' journalctl -u ideal-magic-web --no-pager -n 40 >&2
else
  sudo journalctl -u ideal-magic-web --no-pager -n 40 >&2
fi
exit 1
