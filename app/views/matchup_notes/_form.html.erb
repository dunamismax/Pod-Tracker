<% if matchup_note.errors.any? %>
  <div class="rounded-lg border border-red-900 bg-red-950/40 p-4 text-sm text-red-100">
    <p class="font-medium">Fix the note before saving:</p>
    <ul class="mt-2 list-disc space-y-1 pl-5">
      <% matchup_note.errors.full_messages.each do |message| %>
        <li><%= message %></li>
      <% end %>
    </ul>
  </div>
<% end %>

<%= form_with model: matchup_note, local: true, class: "space-y-5" do |form| %>
  <div class="grid gap-4 sm:grid-cols-2">
    <div>
      <%= form.label :deck_id, "Deck", class: "block text-xs font-medium text-zinc-400" %>
      <%= form.collection_select :deck_id, decks, :id, :name, { prompt: "Choose a deck" },
                                 class: "mt-1 block w-full rounded-md border border-zinc-700 bg-zinc-900 px-3 py-2 text-sm text-zinc-100" %>
    </div>

    <div>
      <%= form.label :commander_id, "Commander", class: "block text-xs font-medium text-zinc-400" %>
      <%= form.select :commander_id,
                      options_for_select(commanders.map { |commander| [ "#{commander.deck.name} - #{commander.name}", commander.id ] }, matchup_note.commander_id),
                      { include_blank: "No specific commander" },
                      class: "mt-1 block w-full rounded-md border border-zinc-700 bg-zinc-900 px-3 py-2 text-sm text-zinc-100" %>
    </div>

    <div>
      <%= form.label :opponent_id, "Opponent", class: "block text-xs font-medium text-zinc-400" %>
      <%= form.collection_select :opponent_id, players, :id, :name, { include_blank: "No specific opponent" },
                                 class: "mt-1 block w-full rounded-md border border-zinc-700 bg-zinc-900 px-3 py-2 text-sm text-zinc-100" %>
    </div>

    <div>
      <%= form.label :happened_at, "When", class: "block text-xs font-medium text-zinc-400" %>
      <%= form.datetime_field :happened_at,
                              value: matchup_note.happened_at&.strftime("%Y-%m-%dT%H:%M"),
                              class: "mt-1 block w-full rounded-md border border-zinc-700 bg-zinc-900 px-3 py-2 text-sm text-zinc-100" %>
    </div>

    <div>
      <%= form.label :pod_id, "Saved pod", class: "block text-xs font-medium text-zinc-400" %>
      <%= form.collection_select :pod_id, pods, :id, :name, { include_blank: "No saved pod" },
                                 class: "mt-1 block w-full rounded-md border border-zinc-700 bg-zinc-900 px-3 py-2 text-sm text-zinc-100" %>
    </div>

    <div class="grid grid-cols-[minmax(0,1fr)_8rem] gap-3">
      <div>
        <%= form.label :game_night_id, "Session", class: "block text-xs font-medium text-zinc-400" %>
        <%= form.collection_select :game_night_id, game_nights, :id, :name, { include_blank: "No session" },
                                   class: "mt-1 block w-full rounded-md border border-zinc-700 bg-zinc-900 px-3 py-2 text-sm text-zinc-100" %>
      </div>
      <div>
        <%= form.label :game_night_pod_number, "Pod #", class: "block text-xs font-medium text-zinc-400" %>
        <%= form.number_field :game_night_pod_number, min: 1,
                              class: "mt-1 block w-full rounded-md border border-zinc-700 bg-zinc-900 px-3 py-2 text-sm text-zinc-100" %>
      </div>
    </div>
  </div>

  <div>
    <%= form.label :tag_list, "Tags", class: "block text-xs font-medium text-zinc-400" %>
    <%= form.text_field :tag_list,
                        placeholder: "mana screw, fast combo, salt check",
                        class: "mt-1 block w-full rounded-md border border-zinc-700 bg-zinc-900 px-3 py-2 text-sm text-zinc-100" %>
  </div>

  <div>
    <%= form.label :body, "Note", class: "block text-xs font-medium text-zinc-400" %>
    <%= form.text_area :body, rows: 8,
                       placeholder: "What mattered in this matchup?",
                       class: "mt-1 block w-full rounded-md border border-zinc-700 bg-zinc-900 px-3 py-2 text-sm leading-6 text-zinc-100" %>
  </div>

  <div class="flex flex-wrap gap-3">
    <%= form.submit matchup_note.persisted? ? "Update note" : "Save note",
                    class: "rounded-md bg-emerald-600 px-3.5 py-2.5 text-sm font-medium text-white hover:bg-emerald-500" %>
    <%= link_to "Cancel", matchup_notes_path, class: "rounded-md bg-zinc-800 px-3.5 py-2.5 text-sm font-medium text-white hover:bg-zinc-700" %>
  </div>
<% end %>
