<% content_for :title, "Matchup note" %>

<section class="mx-auto w-full max-w-3xl space-y-6">
  <div class="flex flex-wrap items-start justify-between gap-4">
    <div>
      <p class="text-sm font-medium uppercase tracking-wide text-emerald-300">Matchup journal</p>
      <h1 class="mt-1 text-2xl font-semibold text-white"><%= @matchup_note.deck.name %></h1>
      <p class="mt-2 text-sm text-zinc-400">
        <%= @matchup_note.happened_at.to_fs(:long) %>
        <% if @matchup_note.commander %> · <%= @matchup_note.commander.name %><% end %>
        <% if @matchup_note.opponent %> · vs <%= @matchup_note.opponent.name %><% end %>
      </p>
    </div>
    <div class="flex flex-wrap gap-2">
      <%= link_to "Edit", edit_matchup_note_path(@matchup_note), class: "rounded-md bg-zinc-800 px-3 py-2 text-sm font-medium text-white hover:bg-zinc-700" %>
      <%= button_to "Remove", matchup_note_path(@matchup_note), method: :delete,
                    form: { data: { turbo_confirm: "Remove this matchup note?" } },
                    class: "rounded-md border border-red-900 px-3 py-2 text-sm font-medium text-red-200 hover:bg-red-950/50" %>
    </div>
  </div>

  <div class="rounded-lg border border-zinc-800 bg-zinc-900 p-5">
    <dl class="grid gap-4 text-sm sm:grid-cols-2">
      <% if @matchup_note.game_night %>
        <div>
          <dt class="text-xs uppercase tracking-wide text-zinc-500">Session</dt>
          <dd class="mt-1 text-zinc-200">
            <%= link_to @matchup_note.game_night.name, game_night_path(@matchup_note.game_night), class: "text-emerald-300 hover:text-emerald-200" %>
            <% if @matchup_note.game_night_pod_number.present? %>
              · Pod <%= @matchup_note.game_night_pod_number %>
            <% end %>
          </dd>
        </div>
      <% end %>
      <% if @matchup_note.pod %>
        <div>
          <dt class="text-xs uppercase tracking-wide text-zinc-500">Saved pod</dt>
          <dd class="mt-1"><%= link_to @matchup_note.pod.name, pod_path(@matchup_note.pod), class: "text-emerald-300 hover:text-emerald-200" %></dd>
        </div>
      <% end %>
      <% if @matchup_note.tags.any? %>
        <div class="sm:col-span-2">
          <dt class="text-xs uppercase tracking-wide text-zinc-500">Tags</dt>
          <dd class="mt-2 flex flex-wrap gap-2">
            <% @matchup_note.tags.each do |tag| %>
              <%= link_to tag, matchup_notes_path(tag: tag), class: "rounded-md bg-zinc-800 px-2 py-1 text-xs text-zinc-300 hover:bg-zinc-700" %>
            <% end %>
          </dd>
        </div>
      <% end %>
    </dl>
  </div>

  <article class="rounded-lg border border-zinc-800 bg-zinc-900 p-5">
    <p class="whitespace-pre-line text-sm leading-6 text-zinc-200"><%= @matchup_note.body %></p>
  </article>
</section>
