<% content_for :title, "Edit matchup note" %>

<section class="mx-auto w-full max-w-3xl space-y-6">
  <div>
    <h1 class="text-2xl font-semibold text-white">Edit matchup note</h1>
    <p class="mt-1 text-sm text-zinc-400">Keep the table memory accurate as the playgroup learns.</p>
  </div>

  <%= render "form",
             matchup_note: @matchup_note,
             decks: @decks,
             commanders: @commanders,
             players: @players,
             pods: @pods,
             game_nights: @game_nights %>
</section>
