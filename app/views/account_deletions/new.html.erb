<div class="mx-auto md:w-2/3 w-full">
  <% if alert = flash[:alert] %>
    <p class="py-2 px-3 bg-red-50 mb-5 text-red-500 font-medium rounded-lg inline-block" id="alert"><%= alert %></p>
  <% end %>

  <h1 class="font-bold text-4xl">Delete account</h1>

  <p class="my-4 text-zinc-300">
    This permanently removes your account, decks, deck cards, commanders, provider links,
    pod evaluations, and analysis scorecards. Audit events tied to your account are
    retained without your user reference for operational integrity.
  </p>

  <p class="my-4 text-zinc-400 text-sm">
    Want a copy of your data first?
    <%= button_to "Download account export", account_export_path, method: :post, class: "underline" %>
  </p>

  <%= form_with url: account_deletion_path, method: :delete, local: true, class: "contents" do |form| %>
    <div class="my-5">
      <%= form.label :current_password, "Confirm with your password", class: "block text-sm font-medium text-zinc-100" %>
      <%= form.password_field :current_password, autocomplete: "current-password", required: true, class: "block shadow-sm rounded-md border border-gray-400 focus:outline-blue-600 px-3 py-2 mt-2 w-full text-zinc-900" %>
    </div>

    <div class="flex gap-4 text-sm">
      <%= form.submit "Delete my account", data: { turbo_confirm: "This cannot be undone. Delete account?" }, class: "rounded-md px-3.5 py-2.5 bg-red-600 hover:bg-red-500 text-white font-medium cursor-pointer" %>
      <%= link_to "Cancel", account_path, class: "rounded-md px-3.5 py-2.5 bg-zinc-800 hover:bg-zinc-700 text-white font-medium" %>
    </div>
  <% end %>
</div>
