<%#
  Ideal Magic service worker.

  Strategy:
    - App shell (CSS/JS/icon/manifest): cache-first with background revalidate.
    - Same-origin GET navigations to whitelisted app pages: network-first with
      cache fallback so a recently visited deck or analysis stays readable
      offline.
    - Everything else: pass through to the network.

  Cache version is derived from the asset version + the app revision. Bumping
  Rails.application.config.assets.version (or any deploy that changes the
  importmap) invalidates the cache automatically. On activate the worker
  drops every cache that does not match the current name and claims clients,
  so users do not get trapped on stale assets.
%>
<%
  cache_version = [
    Rails.application.config.assets.version,
    (Rails.application.config.try(:revision) || ENV["APP_REVISION"] || "dev")
  ].compact.join("-")
  shell_paths = [
    "/",
    "/manifest.json",
    "/icon.png"
  ]
%>
const CACHE_VERSION = <%== cache_version.to_json %>;
const SHELL_CACHE = `ideal-magic-shell-${CACHE_VERSION}`;
const PAGES_CACHE_PREFIX = "ideal-magic-pages-";
const PAGES_CACHE = `${PAGES_CACHE_PREFIX}${CACHE_VERSION}`;
const SHELL_PATHS = <%== shell_paths.to_json %>;
const PAGE_ALLOWLIST = [
  /^\/app\/?$/,
  /^\/decks\/?$/,
  /^\/decks\/[^\/?#]+\/?$/,
  /^\/pods\/?$/,
  /^\/pods\/[^\/?#]+\/?$/,
  /^\/sessions\/?$/,
  /^\/sessions\/[^\/?#]+\/?$/
];

self.addEventListener("install", (event) => {
  event.waitUntil((async () => {
    const cache = await caches.open(SHELL_CACHE);
    await Promise.all(SHELL_PATHS.map(async (path) => {
      try { await cache.add(new Request(path, { credentials: "same-origin" })); }
      catch (_e) { /* shell entry missing on this deploy; skip */ }
    }));
    await self.skipWaiting();
  })());
});

self.addEventListener("activate", (event) => {
  event.waitUntil((async () => {
    const names = await caches.keys();
    await Promise.all(names.map((name) => {
      if (name !== SHELL_CACHE && name !== PAGES_CACHE && name.startsWith("ideal-magic-")) {
        return caches.delete(name);
      }
      return null;
    }));
    await self.clients.claim();
  })());
});

self.addEventListener("message", (event) => {
  if (event.data && event.data.type === "SKIP_WAITING") {
    self.skipWaiting();
  } else if (event.data && event.data.type === "CLEAR_PAGE_CACHE") {
    event.waitUntil(deletePageCaches());
  }
});

function isShellRequest(url) {
  if (url.pathname === "/manifest.json" || url.pathname === "/icon.png") return true;
  if (url.pathname.startsWith("/assets/")) return true;
  return false;
}

function isCachablePage(url) {
  return PAGE_ALLOWLIST.some((rx) => rx.test(url.pathname));
}

self.addEventListener("fetch", (event) => {
  const request = event.request;
  if (request.method !== "GET") return;

  const url = new URL(request.url);
  if (url.origin !== self.location.origin) return;

  if (isShellRequest(url)) {
    event.respondWith(cacheFirst(request, SHELL_CACHE));
    return;
  }

  if (request.mode === "navigate" && isCachablePage(url)) {
    event.respondWith(networkFirstPage(request));
    return;
  }
});

async function cacheFirst(request, cacheName) {
  const cache = await caches.open(cacheName);
  const cached = await cache.match(request);
  if (cached) {
    revalidate(cache, request);
    return cached;
  }
  try {
    const response = await fetch(request);
    if (response && response.ok) cache.put(request, response.clone());
    return response;
  } catch (_e) {
    return cached || Response.error();
  }
}

function revalidate(cache, request) {
  fetch(request).then((response) => {
    if (response && response.ok) cache.put(request, response.clone());
  }).catch(() => {});
}

async function networkFirstPage(request) {
  const cache = await caches.open(PAGES_CACHE);
  try {
    const response = await fetch(request);
    if (response && response.ok && response.type === "basic") {
      cache.put(request, response.clone());
    }
    return response;
  } catch (_e) {
    const cached = await cache.match(request);
    if (cached) {
      const headers = new Headers(cached.headers);
      headers.set("X-Ideal-Magic-Offline", "1");
      return new Response(await cached.blob(), {
        status: cached.status,
        statusText: cached.statusText,
        headers
      });
    }
    return Response.error();
  }
}

async function deletePageCaches() {
  const names = await caches.keys();
  await Promise.all(names.map((name) => {
    if (name.startsWith(PAGES_CACHE_PREFIX)) {
      return caches.delete(name);
    }
    return null;
  }));
}
