<% content_for :title, "Collection" %>

<section class="space-y-6">
  <div class="flex flex-wrap items-end justify-between gap-4">
    <div>
      <h1 class="text-2xl font-semibold text-white">Your collection</h1>
      <p class="mt-1 text-sm text-zinc-400">
        Track owned card quantities so deck pages can show what is ready and what is missing.
      </p>
    </div>
    <%= link_to "Import a deck", new_deck_path, class: "rounded-md bg-zinc-800 px-3.5 py-2.5 text-sm font-medium text-white hover:bg-zinc-700" %>
  </div>

  <div class="grid gap-6 lg:grid-cols-[minmax(0,1fr)_22rem]">
    <div class="space-y-6">
      <div class="rounded-lg border border-zinc-800 bg-zinc-900 p-5">
        <h2 class="text-lg font-medium text-white">Add cards</h2>
        <%= form_with url: collection_cards_path, scope: :collection_card, local: true, class: "mt-4 grid gap-3 sm:grid-cols-[minmax(0,1fr)_7rem_auto]", data: { offline_disable: true } do |form| %>
          <div>
            <%= form.label :name, "Card name", class: "text-sm font-medium text-zinc-200" %>
            <%= form.text_field :name, class: "mt-1 w-full rounded-md border border-zinc-700 bg-zinc-950 px-3 py-2 text-sm text-white", placeholder: "Sol Ring" %>
          </div>
          <div>
            <%= form.label :quantity, "Qty", class: "text-sm font-medium text-zinc-200" %>
            <%= form.number_field :quantity, value: 1, min: 1, class: "mt-1 w-full rounded-md border border-zinc-700 bg-zinc-950 px-3 py-2 text-sm text-white" %>
          </div>
          <div class="self-end">
            <%= form.submit "Add", class: "w-full rounded-md bg-emerald-600 px-3.5 py-2.5 text-sm font-medium text-white hover:bg-emerald-500" %>
          </div>
        <% end %>
      </div>

      <div class="rounded-lg border border-zinc-800 bg-zinc-900 p-5">
        <h2 class="text-lg font-medium text-white">Import collection</h2>
        <% if @import_form.errors.any? %>
          <div class="mt-3 rounded-md border border-red-900 bg-red-950/50 p-3 text-sm text-red-200">
            <ul class="list-disc pl-5">
              <% @import_form.errors.full_messages.each do |message| %>
                <li><%= message %></li>
              <% end %>
            </ul>
          </div>
        <% end %>
        <%= form_with model: @import_form, url: collection_imports_path, scope: :collection_import_form, local: true, multipart: true, class: "mt-4 space-y-4", data: { offline_disable: true } do |form| %>
          <div>
            <%= form.label :collection_list, "Paste text or CSV", class: "text-sm font-medium text-zinc-200" %>
            <%= form.text_area :collection_list, rows: 8, class: "mt-1 w-full rounded-md border border-zinc-700 bg-zinc-950 px-3 py-2 font-mono text-sm text-white", placeholder: "2 Sol Ring&#10;4 Arcane Signet&#10;&#10;or CSV: name,quantity".html_safe %>
          </div>
          <div>
            <%= form.label :collection_file, "Upload text or CSV", class: "text-sm font-medium text-zinc-200" %>
            <%= form.file_field :collection_file, accept: ".txt,.csv,text/plain,text/csv", class: "mt-1 block w-full rounded-md border border-zinc-700 bg-zinc-950 px-3 py-2 text-sm text-zinc-200" %>
          </div>
          <%= form.submit "Import collection", class: "rounded-md bg-emerald-600 px-3.5 py-2.5 text-sm font-medium text-white hover:bg-emerald-500" %>
        <% end %>
      </div>

      <div class="rounded-lg border border-zinc-800 bg-zinc-900">
        <div class="border-b border-zinc-800 p-5">
          <h2 class="text-lg font-medium text-white">Owned cards</h2>
          <p class="mt-1 text-sm text-zinc-400"><%= pluralize(@collection_cards.sum(&:quantity), "card") %> across <%= pluralize(@collection_cards.size, "unique name") %>.</p>
        </div>
        <% if @collection_cards.empty? %>
          <p class="p-5 text-sm text-zinc-400">No collection cards yet.</p>
        <% else %>
          <ul class="divide-y divide-zinc-800">
            <% @collection_cards.each do |card| %>
              <li class="grid gap-3 p-4 sm:grid-cols-[minmax(0,1fr)_12rem_auto] sm:items-center">
                <div>
                  <p class="font-medium text-zinc-100"><%= card.name %></p>
                  <p class="text-xs uppercase tracking-wide text-zinc-500"><%= card.source_type %></p>
                </div>
                <%= form_with model: card, url: collection_card_path(card), method: :patch, local: true, scope: :collection_card, class: "flex items-center gap-2" do |form| %>
                  <%= form.label :quantity, "Qty", class: "text-xs uppercase tracking-wide text-zinc-500" %>
                  <%= form.number_field :quantity, min: 0, class: "w-20 rounded-md border border-zinc-700 bg-zinc-950 px-2 py-1.5 text-sm text-white" %>
                  <%= form.submit "Save", class: "rounded-md bg-zinc-800 px-3 py-1.5 text-sm font-medium text-white hover:bg-zinc-700" %>
                <% end %>
                <%= button_to "Remove", collection_card_path(card), method: :delete, form: { data: { turbo_confirm: "Remove #{card.name} from your collection?" } }, class: "rounded-md border border-red-900 px-3 py-1.5 text-sm font-medium text-red-200 hover:bg-red-950" %>
              </li>
            <% end %>
          </ul>
        <% end %>
      </div>
    </div>

    <aside class="space-y-6">
      <div class="rounded-lg border border-zinc-800 bg-zinc-900 p-5">
        <h2 class="text-lg font-medium text-white">Demand pressure</h2>
        <p class="mt-1 text-sm text-zinc-400">Missing cards that block the most decks.</p>
        <% if @demand_pressure.entries.empty? %>
          <p class="mt-3 text-sm text-zinc-400">No deck gaps found.</p>
        <% else %>
          <% pressure_entries = @demand_pressure.shared_entries.presence || @demand_pressure.entries %>
          <ul class="mt-4 space-y-3 text-sm">
            <% pressure_entries.first(8).each do |entry| %>
              <li class="rounded-md border border-zinc-800 bg-zinc-950 p-3">
                <p class="font-medium text-zinc-100"><%= entry.name %></p>
                <p class="mt-1 text-xs text-zinc-500">
                  Missing <%= pluralize(entry.total_missing_quantity, "copy") %>
                  across <%= pluralize(entry.deck_count, "deck") %>
                </p>
                <p class="mt-1 text-xs text-zinc-400"><%= entry.deck_names.first(4).to_sentence %></p>
              </li>
            <% end %>
          </ul>
        <% end %>
      </div>

      <div class="rounded-lg border border-zinc-800 bg-zinc-900 p-5">
        <h2 class="text-lg font-medium text-white">Needs review</h2>
        <% if @open_unresolved_entries.empty? %>
          <p class="mt-3 text-sm text-zinc-400">No unresolved collection rows.</p>
        <% else %>
          <ul class="mt-4 space-y-4">
            <% @open_unresolved_entries.each do |entry| %>
              <li class="rounded-md border border-zinc-800 bg-zinc-950 p-3">
                <p class="text-sm font-medium text-zinc-100"><%= entry.name.presence || entry.raw_line %></p>
                <p class="mt-1 text-xs text-zinc-500"><%= entry.reason %> · Qty <%= entry.quantity %></p>
                <%= form_with model: entry, url: unresolved_entry_path(entry), method: :patch, local: true, scope: :unresolved_entry, class: "mt-3 space-y-2" do |form| %>
                  <%= form.text_field :name, value: entry.name, class: "w-full rounded-md border border-zinc-700 bg-zinc-950 px-2 py-1.5 text-sm text-white", placeholder: "Correct card name" %>
                  <div class="flex gap-2">
                    <%= form.submit "Resolve", class: "rounded-md bg-emerald-600 px-3 py-1.5 text-sm font-medium text-white hover:bg-emerald-500" %>
                    <%= form.submit "Ignore", class: "rounded-md border border-zinc-700 px-3 py-1.5 text-sm font-medium text-zinc-200 hover:bg-zinc-800" %>
                  </div>
                <% end %>
              </li>
            <% end %>
          </ul>
        <% end %>
      </div>

      <div class="rounded-lg border border-zinc-800 bg-zinc-900 p-5">
        <h2 class="text-lg font-medium text-white">Recent imports</h2>
        <% if @recent_imports.empty? %>
          <p class="mt-3 text-sm text-zinc-400">No collection imports yet.</p>
        <% else %>
          <ul class="mt-4 space-y-3 text-sm">
            <% @recent_imports.each do |collection_import| %>
              <li>
                <%= link_to collection_import.created_at.to_fs(:short), collection_import_path(collection_import), class: "font-medium text-emerald-300 hover:text-emerald-200" %>
                <p class="text-xs text-zinc-500"><%= collection_import.imported_count %> imported · <%= collection_import.unresolved_count %> unresolved</p>
              </li>
            <% end %>
          </ul>
        <% end %>
      </div>
    </aside>
  </div>
</section>
