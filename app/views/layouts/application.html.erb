<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Ideal Magic" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Ideal Magic">
    <meta name="mobile-web-app-capable" content="yes">
    <% if content_for?(:meta_description) %>
      <meta name="description" content="<%= strip_tags(content_for(:meta_description)) %>">
      <meta property="og:description" content="<%= strip_tags(content_for(:meta_description)) %>">
    <% else %>
      <meta name="description" content="Ideal Magic — the serious Commander companion. Bracket-aware deck and pod analysis, source-backed, evidence-first.">
    <% end %>
    <meta property="og:title" content="<%= content_for(:title) || 'Ideal Magic' %>">
    <meta property="og:site_name" content="Ideal Magic">
    <meta property="og:type" content="website">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="apple-touch-icon" href="/icon.png">
    <% canonical_url = (content_for(:canonical_url).presence || request.original_url) %>
    <link rel="canonical" href="<%= canonical_url %>">
    <meta property="og:url" content="<%= canonical_url %>">
    <% og_image = "#{request.protocol}#{request.host_with_port}/hero-screens.png" %>
    <meta property="og:image" content="<%= og_image %>">
    <meta property="og:image:alt" content="Ideal Magic — Commander Brackets, six-axis sub-band, and Rule 0 pregame template">
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="<%= content_for(:title) || 'Ideal Magic' %>">
    <% if content_for?(:meta_description) %>
      <meta name="twitter:description" content="<%= strip_tags(content_for(:meta_description)) %>">
    <% else %>
      <meta name="twitter:description" content="Ideal Magic — the serious Commander companion. Bracket-aware deck and pod analysis, source-backed, evidence-first.">
    <% end %>
    <meta name="twitter:image" content="<%= og_image %>">
    <% site_origin = "#{request.protocol}#{request.host_with_port}" %>
    <%= jsonld_tag(
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "Organization",
          "@id": "#{site_origin}/#organization",
          "name": "Ideal Magic",
          "url": "#{site_origin}/",
          "logo": "#{site_origin}/icon.png",
          "sameAs": [ "https://github.com/dunamismax/ideal-magic" ]
        },
        {
          "@type": "WebSite",
          "@id": "#{site_origin}/#website",
          "url": "#{site_origin}/",
          "name": "Ideal Magic",
          "description": "Bracket-aware Commander companion: deterministic deck analysis, pod Rule 0 briefs, evidence-first scoring.",
          "publisher": { "@id": "#{site_origin}/#organization" }
        }
      ]
    ) %>
    <%= content_for(:jsonld_extra) %>

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-zinc-950 text-zinc-100 antialiased">
    <header class="border-b border-zinc-900 bg-zinc-950/95 backdrop-blur supports-[backdrop-filter]:bg-zinc-950/80">
      <div class="mx-auto flex w-full max-w-6xl items-center justify-between gap-4 px-4 py-3 sm:px-6 lg:px-8">
        <%= link_to root_path, class: "flex items-center gap-2 text-sm font-semibold text-white" do %>
          <span class="inline-block h-2 w-2 rounded-full bg-emerald-400"></span>
          <span>Ideal Magic</span>
        <% end %>

        <nav class="hidden items-center gap-5 text-sm text-zinc-300 sm:flex">
          <% if authenticated? %>
            <%= link_to "Decks", decks_path, class: "hover:text-white" %>
            <%= link_to "Collection", collection_path, class: "hover:text-white" %>
            <%= link_to "Pods", pods_path, class: "hover:text-white" %>
            <%= link_to "Sessions", game_nights_path, class: "hover:text-white" %>
            <%= link_to "Site", root_path, class: "hover:text-white" %>
          <% else %>
            <%= link_to "Brackets", brackets_path, class: "hover:text-white" %>
            <%= link_to "Game Changers", game_changers_path, class: "hover:text-white" %>
            <%= link_to "Pregame template", pregame_template_path, class: "hover:text-white" %>
            <%= link_to "About", about_path, class: "hover:text-white" %>
          <% end %>
        </nav>

        <div class="flex items-center gap-2 text-sm">
          <% if authenticated? %>
            <%= link_to "Open app", app_dashboard_path, class: "rounded-md bg-emerald-600 px-3 py-1.5 font-medium text-white hover:bg-emerald-500" %>
            <%= button_to "Sign out", session_path, method: :delete, form: { class: "inline" }, class: "rounded-md border border-zinc-800 px-3 py-1.5 text-zinc-200 hover:bg-zinc-900" %>
          <% else %>
            <%= link_to "Sign in", new_session_path, class: "rounded-md border border-zinc-800 px-3 py-1.5 text-zinc-200 hover:bg-zinc-900" %>
            <%= link_to "Create account", new_registration_path, class: "rounded-md bg-emerald-600 px-3 py-1.5 font-medium text-white hover:bg-emerald-500" %>
          <% end %>
        </div>
      </div>
    </header>

    <main class="mx-auto flex min-h-[calc(100vh-8rem)] w-full max-w-6xl flex-col px-4 py-8 sm:px-6 lg:px-8">
      <% if alert = flash[:alert] %>
        <p class="py-2 px-3 mb-5 rounded-lg bg-red-50 text-red-600 font-medium" id="alert"><%= alert %></p>
      <% end %>
      <% if notice = flash[:notice] %>
        <p class="py-2 px-3 mb-5 rounded-lg bg-emerald-50 text-emerald-700 font-medium" id="notice"><%= notice %></p>
      <% end %>
      <%= yield %>
    </main>

    <footer class="border-t border-zinc-900">
      <div class="mx-auto flex w-full max-w-6xl flex-col gap-3 px-4 py-6 text-xs text-zinc-500 sm:flex-row sm:items-center sm:justify-between sm:px-6 lg:px-8">
        <div>
          <p>Ideal Magic is unofficial fan content. Not approved or endorsed by Wizards of the Coast.</p>
          <p class="mt-1">Card data via <a href="https://scryfall.com" class="underline hover:text-zinc-300">Scryfall</a>. Commander rules via <a href="https://mtgcommander.net" class="underline hover:text-zinc-300">mtgcommander.net</a>. Brackets reference Wizards' published Commander Brackets system.</p>
        </div>
        <nav class="flex flex-wrap gap-4">
          <%= link_to "About", about_path, class: "hover:text-zinc-300" %>
          <%= link_to "Privacy", privacy_path, class: "hover:text-zinc-300" %>
          <%= link_to "Terms", terms_path, class: "hover:text-zinc-300" %>
          <a href="https://github.com/dunamismax/ideal-magic" class="hover:text-zinc-300">GitHub</a>
        </nav>
      </div>
    </footer>
  </body>
</html>
