<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Pod Tracker" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover">
    <meta name="theme-color" content="#09090b">
    <meta name="color-scheme" content="dark">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-title" content="Pod Tracker">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <meta name="application-name" content="Pod Tracker">
    <meta name="mobile-web-app-capable" content="yes">
    <% if content_for?(:meta_description) %>
      <meta name="description" content="<%= strip_tags(content_for(:meta_description)) %>">
      <meta property="og:description" content="<%= strip_tags(content_for(:meta_description)) %>">
    <% else %>
      <meta name="description" content="Pod Tracker — the serious Commander companion. Bracket-aware deck and pod analysis, source-backed, evidence-first.">
    <% end %>
    <meta property="og:title" content="<%= content_for(:title) || 'Pod Tracker' %>">
    <meta property="og:site_name" content="Pod Tracker">
    <meta property="og:type" content="website">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="manifest" href="<%= pwa_manifest_path %>">
    <link rel="icon" href="/icon.png" type="image/png" sizes="any">
    <link rel="apple-touch-icon" href="/icon.png">
    <% canonical_url = (content_for(:canonical_url).presence || request.original_url) %>
    <link rel="canonical" href="<%= canonical_url %>">
    <meta property="og:url" content="<%= canonical_url %>">
    <% og_image = "#{request.protocol}#{request.host_with_port}/hero-screens.png" %>
    <meta property="og:image" content="<%= og_image %>">
    <meta property="og:image:alt" content="Pod Tracker — Commander Brackets, six-axis sub-band, and Rule 0 pregame template">
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="<%= content_for(:title) || 'Pod Tracker' %>">
    <% if content_for?(:meta_description) %>
      <meta name="twitter:description" content="<%= strip_tags(content_for(:meta_description)) %>">
    <% else %>
      <meta name="twitter:description" content="Pod Tracker — the serious Commander companion. Bracket-aware deck and pod analysis, source-backed, evidence-first.">
    <% end %>
    <meta name="twitter:image" content="<%= og_image %>">
    <% site_origin = "#{request.protocol}#{request.host_with_port}" %>
    <%= jsonld_tag(
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "Organization",
          "@id": "#{site_origin}/#organization",
          "name": "Pod Tracker",
          "url": "#{site_origin}/",
          "logo": "#{site_origin}/icon.png",
          "sameAs": [ "https://github.com/dunamismax/pod-tracker" ]
        },
        {
          "@type": "WebSite",
          "@id": "#{site_origin}/#website",
          "url": "#{site_origin}/",
          "name": "Pod Tracker",
          "description": "Bracket-aware Commander companion: deterministic deck analysis, pod Rule 0 briefs, evidence-first scoring.",
          "publisher": { "@id": "#{site_origin}/#organization" }
        }
      ]
    ) %>
    <%= content_for(:jsonld_extra) %>

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-zinc-950 text-zinc-100 antialiased <%= 'pb-16 sm:pb-0' if authenticated? %>"
        data-controller="pwa-update offline"
        data-pwa-update-clear-page-cache-value="<%= flash[:clear_page_cache].present? %>">
    <div data-offline-target="banner" hidden role="status" aria-live="polite"
         class="fixed inset-x-0 top-0 z-50 flex justify-center px-4 pt-2">
      <div class="flex w-full max-w-md items-center gap-3 rounded-lg border border-amber-700/40 bg-amber-950/95 px-4 py-2 text-sm text-amber-100 shadow-lg backdrop-blur">
        <svg viewBox="0 0 24 24" aria-hidden="true" class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 3l18 18M8.5 16.5a5 5 0 017 0M5 13a9 9 0 0114 0M2 9a13 13 0 0120 0" />
        </svg>
        <span class="grow">Offline. Anything you submit is paused until you reconnect — nothing has reached the server yet.</span>
      </div>
    </div>
    <div data-pwa-update-target="banner" hidden role="status" aria-live="polite"
         class="fixed inset-x-0 bottom-16 z-50 flex justify-center px-4 pb-4 sm:bottom-4">
      <div class="flex w-full max-w-md items-center gap-3 rounded-lg border border-emerald-700/40 bg-zinc-900/95 px-4 py-3 text-sm text-zinc-100 shadow-lg backdrop-blur">
        <span class="grow">A new version of Pod Tracker is ready.</span>
        <button type="button" data-action="pwa-update#reload"
                class="rounded-md bg-emerald-600 px-3 py-1.5 font-medium text-white hover:bg-emerald-500">
          Reload
        </button>
        <button type="button" data-action="pwa-update#dismiss"
                aria-label="Dismiss update prompt"
                class="rounded-md border border-zinc-800 px-2 py-1.5 text-zinc-300 hover:bg-zinc-800">
          ×
        </button>
      </div>
    </div>
    <header class="border-b border-zinc-900 bg-zinc-950/95 backdrop-blur supports-[backdrop-filter]:bg-zinc-950/80">
      <div class="mx-auto flex w-full max-w-6xl items-center justify-between gap-4 px-4 py-3 sm:px-6 lg:px-8">
        <%= link_to root_path, class: "flex items-center gap-2 text-sm font-semibold text-white" do %>
          <span class="inline-block h-2 w-2 rounded-full bg-emerald-400"></span>
          <span>Pod Tracker</span>
        <% end %>

        <nav class="hidden items-center gap-5 text-sm text-zinc-300 sm:flex">
          <% if authenticated? %>
            <%= link_to "Decks", decks_path, class: "hover:text-white" %>
            <%= link_to "Collection", collection_path, class: "hover:text-white" %>
            <%= link_to "Pods", pods_path, class: "hover:text-white" %>
            <%= link_to "Sessions", game_nights_path, class: "hover:text-white" %>
            <%= link_to "Journal", matchup_notes_path, class: "hover:text-white" %>
            <%= link_to "Site", root_path, class: "hover:text-white" %>
          <% else %>
            <%= link_to "Brackets", brackets_path, class: "hover:text-white" %>
            <%= link_to "Game Changers", game_changers_path, class: "hover:text-white" %>
            <%= link_to "Pregame template", pregame_template_path, class: "hover:text-white" %>
            <%= link_to "About", about_path, class: "hover:text-white" %>
          <% end %>
        </nav>

        <div class="flex items-center gap-2 text-sm">
          <% if authenticated? %>
            <%= link_to "Open app", app_dashboard_path, class: "rounded-md bg-emerald-600 px-3 py-1.5 font-medium text-white hover:bg-emerald-500" %>
            <%= link_to "Account", account_path,
                  class: "rounded-md border px-3 py-1.5 hover:bg-zinc-900 #{mobile_nav_section == 'account' ? 'border-emerald-500/60 text-emerald-200' : 'border-zinc-800 text-zinc-200'}",
                  "aria-current": (mobile_nav_section == "account" ? "page" : nil) %>
            <%= button_to "Sign out", session_path, method: :delete, form: { class: "inline" }, class: "rounded-md border border-zinc-800 px-3 py-1.5 text-zinc-200 hover:bg-zinc-900" %>
          <% else %>
            <%= link_to "Sign in", new_session_path, class: "rounded-md border border-zinc-800 px-3 py-1.5 text-zinc-200 hover:bg-zinc-900" %>
            <%= link_to "Create account", new_registration_path, class: "rounded-md bg-emerald-600 px-3 py-1.5 font-medium text-white hover:bg-emerald-500" %>
          <% end %>
        </div>
      </div>
    </header>

    <main class="mx-auto flex min-h-[calc(100vh-8rem)] w-full max-w-6xl flex-col px-4 py-8 sm:px-6 lg:px-8">
      <% if alert = flash[:alert] %>
        <p class="py-2 px-3 mb-5 rounded-lg bg-red-50 text-red-600 font-medium" id="alert"><%= alert %></p>
      <% end %>
      <% if notice = flash[:notice] %>
        <p class="py-2 px-3 mb-5 rounded-lg bg-emerald-50 text-emerald-700 font-medium" id="notice"><%= notice %></p>
      <% end %>
      <%= yield %>
    </main>

    <%= render "shared/mobile_bottom_nav" if authenticated? %>

    <footer class="border-t border-zinc-900">
      <div class="mx-auto flex w-full max-w-6xl flex-col gap-3 px-4 py-6 text-xs text-zinc-500 sm:flex-row sm:items-center sm:justify-between sm:px-6 lg:px-8">
        <div>
          <p>Pod Tracker is unofficial fan content. Not approved or endorsed by Wizards of the Coast.</p>
          <p class="mt-1">Card data via <a href="https://scryfall.com" class="underline hover:text-zinc-300">Scryfall</a>. Commander rules via <a href="https://mtgcommander.net" class="underline hover:text-zinc-300">mtgcommander.net</a>. Brackets reference Wizards' published Commander Brackets system.</p>
        </div>
        <nav class="flex flex-wrap gap-4">
          <%= link_to "About", about_path, class: "hover:text-zinc-300" %>
          <%= link_to "Privacy", privacy_path, class: "hover:text-zinc-300" %>
          <%= link_to "Terms", terms_path, class: "hover:text-zinc-300" %>
          <a href="https://github.com/dunamismax/pod-tracker" class="hover:text-zinc-300">GitHub</a>
        </nav>
      </div>
    </footer>
  </body>
</html>
