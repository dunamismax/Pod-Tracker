<% content_for :title, "Invitation" %>

<section class="mx-auto w-full max-w-2xl space-y-6">
  <div>
    <p class="text-sm font-medium uppercase tracking-wide text-emerald-300">You're invited</p>
    <h1 class="mt-1 text-3xl font-semibold text-white"><%= @game_night.name %></h1>
    <p class="mt-2 text-sm text-zinc-400">
      <%= @game_night.played_on.to_fs(:long) %>
      <% if @game_night.location.present? %>· <%= @game_night.location %><% end %>
      · hosted by <%= @game_night.user.attribution_name %>
    </p>
  </div>

  <% if @game_night.notes.present? %>
    <div class="rounded-md border border-zinc-800 bg-zinc-900 p-4 text-sm text-zinc-300 whitespace-pre-line"><%= @game_night.notes %></div>
  <% end %>

  <% if @invitation.message.present? %>
    <div class="rounded-md border border-zinc-800 bg-zinc-950/60 p-4">
      <p class="text-xs font-medium uppercase tracking-wide text-zinc-500">Note from the host</p>
      <p class="mt-2 whitespace-pre-line text-sm text-zinc-200"><%= @invitation.message %></p>
    </div>
  <% end %>

  <% if flash[:alert] %>
    <div class="rounded-md border border-red-800 bg-red-950/40 p-3 text-sm text-red-200"><%= flash[:alert] %></div>
  <% end %>
  <% if flash[:notice] %>
    <div class="rounded-md border border-emerald-800 bg-emerald-950/40 p-3 text-sm text-emerald-200"><%= flash[:notice] %></div>
  <% end %>

  <div class="rounded-md border border-zinc-800 bg-zinc-900 p-4">
    <p class="text-xs font-medium uppercase tracking-wide text-zinc-500">Status</p>
    <p class="mt-1 text-base font-medium text-white">
      <%= case @invitation.status
          when "accepted" then "Accepted — bringing #{@invitation.deck&.name || 'a deck'}"
          when "declined" then "Declined"
          when "cancelled" then "Cancelled by the host"
          else "Awaiting your response"
          end %>
    </p>
    <% if @invitation.responded_at %>
      <p class="mt-1 text-xs text-zinc-500">Last updated <%= time_ago_in_words(@invitation.responded_at) %> ago</p>
    <% end %>
  </div>

  <% if @invitation.cancelled? %>
    <div class="rounded-md border border-zinc-800 bg-zinc-900 p-4 text-sm text-zinc-400">
      The host cancelled this invitation. Reach out if you think that was a mistake.
    </div>
  <% else %>
    <div class="rounded-lg border border-zinc-800 bg-zinc-900">
      <div class="border-b border-zinc-800 px-5 py-4">
        <h2 class="text-lg font-medium text-white">Pick the deck you're bringing</h2>
        <p class="mt-1 text-sm text-zinc-500">Only you see your decks — the host only sees the deck name and commanders you choose. Change your pick anytime before the session.</p>
      </div>

      <% if @decks.any? %>
        <%= form_with url: accept_invitation_response_path(token: @invitation.token), method: :patch, local: true, class: "space-y-4 p-5", data: { offline_disable: true } do %>
          <div>
            <label for="invitation_deck_id" class="block text-xs font-medium text-zinc-400">Your deck</label>
            <%= select_tag :deck_id,
                           options_from_collection_for_select(@decks, :id, :name, @selected_deck_id),
                           id: "invitation_deck_id",
                           include_blank: "Choose a deck",
                           class: "mt-1 block w-full rounded-md border border-zinc-700 bg-zinc-950 px-3 py-2 text-sm text-zinc-100" %>
            <p class="mt-1 text-xs text-zinc-500">Don't see one? <%= link_to "Import a deck", new_deck_path, class: "text-emerald-300 hover:text-emerald-200" %> and come back.</p>
          </div>

          <div>
            <label for="invitation_response_note" class="block text-xs font-medium text-zinc-400">Optional note for the host</label>
            <%= text_area_tag :response_note, @invitation.response_note, rows: 2, id: "invitation_response_note",
                              placeholder: "Running ten minutes late, but in.",
                              class: "mt-1 block w-full rounded-md border border-zinc-700 bg-zinc-950 px-3 py-2 text-sm text-zinc-100" %>
          </div>

          <div class="flex flex-wrap gap-3">
            <%= submit_tag @invitation.accepted? ? "Update my deck" : "Accept and register deck",
                           class: "rounded-md bg-emerald-600 px-3.5 py-2.5 text-sm font-medium text-white hover:bg-emerald-500" %>
          </div>
        <% end %>
      <% else %>
        <div class="p-5">
          <p class="text-sm text-zinc-300">You don't have any imported decks yet.</p>
          <p class="mt-2 text-xs text-zinc-500">
            <%= link_to "Import a deck", new_deck_path, class: "text-emerald-300 hover:text-emerald-200" %> first, then return here to register the deck you're bringing.
          </p>
        </div>
      <% end %>

      <div class="border-t border-zinc-800 px-5 py-4">
        <%= form_with url: decline_invitation_response_path(token: @invitation.token), method: :patch, local: true, class: "flex flex-col gap-3 sm:flex-row sm:items-end", data: { offline_disable: true, turbo_confirm: "Decline this invite?" } do %>
          <div class="flex-1">
            <label for="decline_response_note" class="block text-xs font-medium text-zinc-400">Decline note (optional)</label>
            <%= text_field_tag :response_note, nil,
                               id: "decline_response_note",
                               autocomplete: "off",
                               placeholder: "Can't make it this week.",
                               class: "mt-1 block w-full rounded-md border border-zinc-700 bg-zinc-950 px-3 py-2 text-sm text-zinc-100" %>
          </div>
          <%= submit_tag "Decline invite",
                         class: "rounded-md border border-red-900 px-3 py-2 text-sm font-medium text-red-200 hover:bg-red-950/50" %>
        <% end %>
      </div>
    </div>
  <% end %>

  <% if @invitation.accepted? %>
    <div class="rounded-md border border-emerald-900/60 bg-emerald-950/30 p-4 text-sm text-emerald-100">
      You're registered. The host will see your deck choice, and you can update it from this page anytime.
    </div>
  <% end %>
</section>
