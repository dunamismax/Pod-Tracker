<% content_for :title, "#{@pod.name} (shared pod)" %>
<%
  meta_summary =
    if @ai_evaluation&.summary.present?
      @ai_evaluation.summary
    elsif @brief["headline"].present?
      @brief["headline"]
    else
      "Commander pod analysis and Rule 0 brief."
    end
  content_for :meta_description, meta_summary
%>

<section class="space-y-6">
  <div class="space-y-2">
    <p class="text-xs uppercase tracking-wide text-emerald-300">Shared Commander pod</p>
    <h1 class="text-2xl font-semibold text-white print:text-zinc-900"><%= @pod.name %></h1>
    <p class="text-sm text-zinc-400 print:text-zinc-700">
      Read-only Rule 0 brief and per-deck scores.
      <% if @ai_evaluation&.completed_at.present? %>
        AI evaluated <%= time_ago_in_words(@ai_evaluation.completed_at) %> ago.
      <% elsif @latest_run&.completed_at %>
        Analyzed <%= time_ago_in_words(@latest_run.completed_at) %> ago.
      <% end %>
    </p>
  </div>

  <div class="rounded-lg border border-zinc-800 bg-zinc-900/60 p-4 text-sm text-zinc-300 print:hidden"
       data-controller="copy-link"
       data-copy-link-url-value="<%= public_pod_url(@pod.share_token) %>">
    <div class="flex flex-wrap items-baseline justify-between gap-3">
      <div>
        <p class="font-medium text-white">Share this pod</p>
        <p class="mt-1 break-all font-mono text-xs text-zinc-400">
          <%= public_pod_url(@pod.share_token) %>
        </p>
      </div>
      <button type="button"
              data-action="copy-link#copy"
              data-copy-link-target="button"
              class="rounded-md bg-emerald-600 px-2.5 py-1.5 text-xs font-medium text-white hover:bg-emerald-500">
        Copy link
      </button>
    </div>
  </div>

  <% if @ai_evaluation.present? %>
    <%= render "pods/ai_analysis", evaluation: @ai_evaluation %>

    <% if @latest_run.present? %>
      <details class="rounded-lg border border-zinc-800 bg-zinc-900/40">
        <summary class="cursor-pointer list-none px-4 py-3 text-sm font-medium text-zinc-300">
          Show preliminary deterministic pod read
          <span class="ml-2 text-xs text-zinc-500">(used before AI evaluation; AI is now authoritative)</span>
        </summary>
        <div class="border-t border-zinc-800 p-4">
          <%= render "pods/analysis", pod: @pod, snapshot: @snapshot, brief: @brief, warnings: @warnings, suggestions: @suggestions, read_only: true %>
        </div>
      </details>
    <% end %>
  <% elsif @latest_run.present? %>
    <%= render "pods/analysis", pod: @pod, snapshot: @snapshot, brief: @brief, warnings: @warnings, suggestions: @suggestions, read_only: true %>
  <% else %>
    <div class="rounded-md border border-zinc-800 bg-zinc-900 p-4 text-sm text-zinc-300">
      Pod analysis not available.
    </div>
  <% end %>

  <p class="rounded-md border border-zinc-800 bg-zinc-900/40 p-4 text-xs text-zinc-500 print:hidden">
    Want to evaluate your own Commander pod like this? <%= link_to "Try Ideal Magic", root_path, class: "underline hover:text-zinc-300" %>.
  </p>
</section>
