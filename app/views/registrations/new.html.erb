<div class="mx-auto md:w-2/3 w-full">
  <% if alert = flash[:alert] %>
    <p class="py-2 px-3 bg-red-50 mb-5 text-red-500 font-medium rounded-lg inline-block" id="alert"><%= alert %></p>
  <% end %>

  <% if notice = flash[:notice] %>
    <p class="py-2 px-3 bg-green-50 mb-5 text-green-500 font-medium rounded-lg inline-block" id="notice"><%= notice %></p>
  <% end %>

  <h1 class="font-bold text-4xl">Create your account</h1>

  <% if @user.errors.any? %>
    <ul class="my-4 text-red-500">
      <% @user.errors.full_messages.each do |message| %>
        <li><%= message %></li>
      <% end %>
    </ul>
  <% end %>

  <%= form_with model: @user, url: registration_path, class: "contents" do |form| %>
    <div class="my-5">
      <%= form.label :email_address, class: "block text-sm font-medium text-zinc-100" %>
      <%= form.email_field :email_address, required: true, autofocus: true, autocomplete: "username", maxlength: 254, class: "block shadow-sm rounded-md border border-gray-400 focus:outline-blue-600 px-3 py-2 mt-2 w-full" %>
    </div>

    <div class="my-5">
      <%= form.label :display_name, "Display name (optional)", class: "block text-sm font-medium text-zinc-100" %>
      <%= form.text_field :display_name, autocomplete: "nickname", maxlength: 60, class: "block shadow-sm rounded-md border border-gray-400 focus:outline-blue-600 px-3 py-2 mt-2 w-full" %>
    </div>

    <div class="my-5">
      <%= form.label :password, class: "block text-sm font-medium text-zinc-100" %>
      <%= form.password_field :password, required: true, autocomplete: "new-password", maxlength: 72, class: "block shadow-sm rounded-md border border-gray-400 focus:outline-blue-600 px-3 py-2 mt-2 w-full" %>
    </div>

    <div class="my-5">
      <%= form.label :password_confirmation, class: "block text-sm font-medium text-zinc-100" %>
      <%= form.password_field :password_confirmation, required: true, autocomplete: "new-password", maxlength: 72, class: "block shadow-sm rounded-md border border-gray-400 focus:outline-blue-600 px-3 py-2 mt-2 w-full" %>
    </div>

    <div class="my-5">
      <%= form.label :timezone, class: "block text-sm font-medium text-zinc-100" %>
      <%= form.time_zone_select :timezone, ActiveSupport::TimeZone.all, {}, class: "block shadow-sm rounded-md border border-gray-400 focus:outline-blue-600 px-3 py-2 mt-2 w-full text-zinc-900" %>
    </div>

    <div class="my-5">
      <%= form.label :preferred_units, class: "block text-sm font-medium text-zinc-100" %>
      <%= form.select :preferred_units, User::PREFERRED_UNITS.map { |u| [u.titleize, u] }, {}, class: "block shadow-sm rounded-md border border-gray-400 focus:outline-blue-600 px-3 py-2 mt-2 w-full text-zinc-900" %>
    </div>

    <div class="col-span-6 sm:flex sm:items-center sm:gap-4">
      <%= form.submit "Create account", class: "w-full sm:w-auto text-center rounded-md px-3.5 py-2.5 bg-blue-600 hover:bg-blue-500 text-white inline-block font-medium cursor-pointer" %>
      <div class="mt-4 text-sm text-zinc-400 sm:mt-0">
        Already have an account? <%= link_to "Sign in", new_session_path, class: "text-zinc-200 underline hover:no-underline" %>
      </div>
    </div>
  <% end %>
</div>
