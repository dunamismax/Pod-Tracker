<% content_for :title, "Import deck" %>

<section class="mx-auto w-full max-w-3xl space-y-6">
  <div>
    <h1 class="text-2xl font-semibold text-white">Import a Commander deck</h1>
    <p class="mt-1 text-sm text-zinc-400">
      Paste a public Archidekt deck URL, upload a plain-text decklist file, or paste a decklist. Use a <code class="rounded bg-zinc-800 px-1 text-xs">Commander</code> header for your commander, or pick one in the form below. Archidekt URL takes precedence, then upload, then paste.
    </p>
  </div>

  <%= form_with model: @form, url: decks_path, scope: :deck_import_form, local: true, multipart: true, class: "space-y-5" do |form| %>
    <% if @form.errors.any? %>
      <div class="rounded-md border border-red-800 bg-red-950/40 p-3 text-sm text-red-200">
        <ul class="list-disc pl-5">
          <% @form.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div>
      <%= form.label :name, "Deck name (optional)", class: "block text-sm font-medium text-zinc-300" %>
      <%= form.text_field :name, class: "mt-1 block w-full rounded-md border border-zinc-700 bg-zinc-900 px-3 py-2 text-zinc-100", placeholder: "Auto-derived from commander if blank" %>
    </div>

    <div>
      <%= form.label :commander_hint, "Commander (optional if your decklist has a Commander header)", class: "block text-sm font-medium text-zinc-300" %>
      <%= form.text_field :commander_hint, class: "mt-1 block w-full rounded-md border border-zinc-700 bg-zinc-900 px-3 py-2 text-zinc-100", placeholder: "e.g. Atraxa, Praetors' Voice" %>
    </div>

    <div>
      <%= form.label :archidekt_url, "Archidekt deck URL (optional)", class: "block text-sm font-medium text-zinc-300" %>
      <%= form.url_field :archidekt_url, class: "mt-1 block w-full rounded-md border border-zinc-700 bg-zinc-900 px-3 py-2 text-zinc-100", placeholder: "https://archidekt.com/decks/12345" %>
      <p class="mt-1 text-xs text-zinc-500">
        Public Archidekt decks only. If a URL is provided it overrides any file upload or pasted text.
      </p>
    </div>

    <div>
      <%= form.label :decklist_file, "Upload a decklist file (optional)", class: "block text-sm font-medium text-zinc-300" %>
      <%= form.file_field :decklist_file, accept: ".txt,.text,.dec,.deck,.cod,.md,.markdown,.csv,text/plain", class: "mt-1 block w-full rounded-md border border-zinc-700 bg-zinc-900 px-3 py-2 text-sm text-zinc-100 file:mr-3 file:rounded file:border-0 file:bg-zinc-800 file:px-3 file:py-1.5 file:text-sm file:text-white file:hover:bg-zinc-700" %>
      <p class="mt-1 text-xs text-zinc-500">
        Plain text only, up to <%= DeckImportForm::MAX_DECKLIST_BYTES / 1024 %> KB. If you upload a file, it overrides any pasted text below.
      </p>
    </div>

    <div>
      <%= form.label :decklist, "Or paste a decklist", class: "block text-sm font-medium text-zinc-300" %>
      <%= form.text_area :decklist, rows: 18, class: "mt-1 block w-full rounded-md border border-zinc-700 bg-zinc-900 px-3 py-2 font-mono text-sm text-zinc-100", placeholder: "1 Sol Ring\n1 Arcane Signet\n..." %>
      <p class="mt-1 text-xs text-zinc-500">
        Lines like <code>1 Sol Ring</code> or <code>1 Sol Ring (CMM) 410</code>. Headers like <code>Commander</code>, <code>Mainboard</code>, or <code>Sideboard</code> route lines to the right pile.
      </p>
    </div>

    <div class="flex flex-wrap gap-3">
      <%= form.submit "Import deck", class: "rounded-md bg-emerald-600 px-3.5 py-2.5 text-sm font-medium text-white hover:bg-emerald-500" %>
      <%= link_to "Cancel", decks_path, class: "rounded-md bg-zinc-800 px-3.5 py-2.5 text-sm font-medium text-white hover:bg-zinc-700" %>
    </div>
  <% end %>
</section>
