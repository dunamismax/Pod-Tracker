<% content_for :title, @deck.name %>

<section class="space-y-6">
  <div class="flex flex-wrap items-baseline justify-between gap-4">
    <div>
      <p class="text-xs uppercase tracking-wide text-emerald-300">Commander deck</p>
      <h1 class="mt-1 text-2xl font-semibold text-white"><%= @deck.name %></h1>
      <p class="mt-1 text-sm text-zinc-400">
        <%= @deck.commander_names.join(", ").presence || "No commander recorded" %>
        <% if @deck.source_type.present? %>
          · Source: <%= @deck.source_type.humanize %>
        <% end %>
        · Imported <%= time_ago_in_words(@deck.last_imported_at || @deck.created_at) %> ago
      </p>
    </div>
    <div class="flex flex-wrap gap-3">
      <%= link_to "All decks", decks_path, class: "rounded-md bg-zinc-800 px-3.5 py-2.5 text-sm font-medium text-white hover:bg-zinc-700" %>
      <%= button_to "Remove deck", deck_path(@deck), method: :delete, form: { data: { turbo_confirm: "Remove this deck?" } }, class: "rounded-md bg-red-700 px-3.5 py-2.5 text-sm font-medium text-white hover:bg-red-600" %>
    </div>
  </div>

  <% unparsed_lines = Array(@deck.import_metadata["unparsed_lines"]) %>
  <% if unparsed_lines.any? %>
    <div class="rounded-md border border-amber-800 bg-amber-950/40 p-4 text-sm text-amber-200">
      <p class="font-medium">Some lines could not be parsed and were skipped:</p>
      <ul class="mt-2 list-disc pl-5 font-mono text-xs">
        <% unparsed_lines.first(20).each do |line| %>
          <li><%= line %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <% if @scorecard.present? %>
    <%= render "analysis", scorecard: @scorecard, run: @analysis_run, legality: @legality, recommendations: @recommendations %>
  <% else %>
    <div class="rounded-md border border-zinc-800 bg-zinc-900 p-4 text-sm text-zinc-300">
      Deterministic analysis has not run for this deck yet.
    </div>
  <% end %>

  <div class="rounded-lg border border-zinc-800 bg-zinc-900 p-5">
    <div class="flex flex-wrap items-baseline justify-between gap-3">
      <div>
        <h2 class="text-lg font-medium text-white">Collection fit</h2>
        <p class="mt-1 text-sm text-zinc-400">
          <%= @ownership.owned_count %>/<%= @ownership.required_count %> cards owned
          <% if @ownership.missing_count.positive? %>
            · <%= @ownership.missing_count %> missing
          <% else %>
            · ready from your collection
          <% end %>
        </p>
      </div>
      <%= link_to "Manage collection", collection_path, class: "rounded-md bg-zinc-800 px-3 py-2 text-sm font-medium text-white hover:bg-zinc-700" %>
    </div>
    <% if @ownership.entries.empty? %>
      <p class="mt-4 text-sm text-zinc-400">No deck cards recorded yet.</p>
    <% elsif @ownership.missing_entries.any? %>
      <ul class="mt-4 grid gap-2 text-sm sm:grid-cols-2 lg:grid-cols-3">
        <% @ownership.missing_entries.first(24).each do |entry| %>
          <li class="rounded-md border border-zinc-800 bg-zinc-950 p-3">
            <p class="font-medium text-zinc-100"><%= entry.name %></p>
            <p class="mt-1 text-xs text-zinc-500">
              Own <%= entry.owned_quantity %> · Need <%= entry.required_quantity %> · Missing <%= entry.missing_quantity %>
            </p>
          </li>
        <% end %>
      </ul>
      <% if @ownership.missing_entries.size > 24 %>
        <p class="mt-3 text-xs text-zinc-500">Showing first 24 missing cards.</p>
      <% end %>
    <% else %>
      <p class="mt-4 text-sm text-emerald-200">Every recorded card in this deck is covered by your collection.</p>
    <% end %>
  </div>

  <div class="grid gap-6 lg:grid-cols-2">
    <% if @deck.commanders.any? %>
      <div class="rounded-lg border border-zinc-800 bg-zinc-900 p-5">
        <h2 class="text-lg font-medium text-white">Commander</h2>
        <ul class="mt-3 space-y-1 text-sm text-zinc-200">
          <% @deck.commanders.order(:position).each do |commander| %>
            <li><%= commander.name %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <% DeckCard::BOARDS.each do |board| %>
      <% cards = @deck.deck_cards.where(board: board).order(:position, :name) %>
      <% next if cards.empty? %>
      <div class="rounded-lg border border-zinc-800 bg-zinc-900 p-5">
        <h2 class="text-lg font-medium text-white"><%= board.humanize %> · <%= cards.sum(&:quantity) %> cards</h2>
        <ul class="mt-3 grid gap-1 text-sm text-zinc-200 sm:grid-cols-2">
          <% cards.each do |card| %>
            <li><span class="text-zinc-500"><%= card.quantity %>×</span> <%= card.name %></li>
          <% end %>
        </ul>
      </div>
    <% end %>
  </div>
</section>
