<% content_for :title, @deck.name %>

<section class="space-y-6">
  <div class="flex flex-wrap items-baseline justify-between gap-4">
    <div>
      <p class="text-xs uppercase tracking-wide text-emerald-300">Commander deck</p>
      <h1 class="mt-1 text-2xl font-semibold text-white"><%= @deck.name %></h1>
      <p class="mt-1 text-sm text-zinc-400">
        <%= @deck.commander_names.join(", ").presence || "No commander recorded" %>
        <% if @deck.source_type.present? %>
          · Source: <%= @deck.source_type.humanize %>
        <% end %>
        · Imported <%= time_ago_in_words(@deck.last_imported_at || @deck.created_at) %> ago
      </p>
    </div>
    <div class="flex flex-wrap gap-3">
      <%= link_to "All decks", decks_path, class: "rounded-md bg-zinc-800 px-3.5 py-2.5 text-sm font-medium text-white hover:bg-zinc-700" %>
      <% if @deck.shared? %>
        <%= button_to "Revoke share link", deck_share_path(@deck), method: :delete, form: { data: { turbo_confirm: "Revoke this deck's public link?" } }, class: "rounded-md bg-zinc-800 px-3.5 py-2.5 text-sm font-medium text-white hover:bg-zinc-700" %>
      <% else %>
        <%= button_to "Create share link", deck_share_path(@deck), method: :post, class: "rounded-md bg-zinc-800 px-3.5 py-2.5 text-sm font-medium text-white hover:bg-zinc-700" %>
      <% end %>
      <%= button_to "Remove deck", deck_path(@deck), method: :delete, form: { data: { turbo_confirm: "Remove this deck?" } }, class: "rounded-md bg-red-700 px-3.5 py-2.5 text-sm font-medium text-white hover:bg-red-600" %>
    </div>
  </div>

  <% if @deck.shared? %>
    <div class="rounded-md border border-emerald-800 bg-emerald-950/30 p-4 text-sm text-emerald-200">
      <p class="font-medium">Public share link</p>
      <p class="mt-1 break-all font-mono text-xs">
        <%= public_deck_url(@deck.share_token) %>
      </p>
      <p class="mt-1 text-xs text-emerald-200/80">
        Anyone with the link can read the decklist and deterministic analysis. Playgroup notes, results, AI evaluations, and collection data stay private. Revoke the link anytime.
      </p>
    </div>
  <% end %>

  <div class="rounded-lg border border-zinc-800 bg-zinc-900/60 p-4">
    <div class="flex flex-wrap items-baseline justify-between gap-3">
      <div>
        <h2 class="text-sm font-medium text-white">Export</h2>
        <p class="mt-1 text-xs text-zinc-500">
          Decklist downloads in plain text, CSV, or JSON. Analysis downloads as Markdown or JSON for sharing or archiving.
        </p>
      </div>
      <div class="flex flex-wrap gap-2 text-xs">
        <span class="text-zinc-500 self-center">Decklist:</span>
        <%= link_to "Text", deck_export_path(@deck, format: :text), class: "rounded-md border border-zinc-700 px-2.5 py-1.5 font-medium text-zinc-200 hover:bg-zinc-800" %>
        <%= link_to "CSV", deck_export_path(@deck, format: :csv), class: "rounded-md border border-zinc-700 px-2.5 py-1.5 font-medium text-zinc-200 hover:bg-zinc-800" %>
        <%= link_to "JSON", deck_export_path(@deck, format: :json), class: "rounded-md border border-zinc-700 px-2.5 py-1.5 font-medium text-zinc-200 hover:bg-zinc-800" %>
        <% if @scorecard.present? %>
          <span class="ml-2 text-zinc-500 self-center">Analysis:</span>
          <%= link_to "Markdown", deck_analysis_export_path(@deck, format: :markdown), class: "rounded-md border border-zinc-700 px-2.5 py-1.5 font-medium text-zinc-200 hover:bg-zinc-800" %>
          <%= link_to "JSON", deck_analysis_export_path(@deck, format: :json), class: "rounded-md border border-zinc-700 px-2.5 py-1.5 font-medium text-zinc-200 hover:bg-zinc-800" %>
        <% end %>
      </div>
    </div>
  </div>

  <% unparsed_lines = Array(@deck.import_metadata["unparsed_lines"]) %>
  <% if unparsed_lines.any? %>
    <div class="rounded-md border border-amber-800 bg-amber-950/40 p-4 text-sm text-amber-200">
      <p class="font-medium">Some lines could not be parsed and were skipped:</p>
      <ul class="mt-2 list-disc pl-5 font-mono text-xs">
        <% unparsed_lines.first(20).each do |line| %>
          <li><%= line %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <% if @ai_evaluation.present? %>
    <%= render "ai_analysis", evaluation: @ai_evaluation, legality: @legality, recommendations: @recommendations %>

    <details class="rounded-lg border border-zinc-800 bg-zinc-900/40">
      <summary class="cursor-pointer list-none px-4 py-3 text-sm font-medium text-zinc-300">
        Show preliminary deterministic read
        <span class="ml-2 text-xs text-zinc-500">(used before AI evaluation; AI is now authoritative)</span>
      </summary>
      <div class="border-t border-zinc-800 p-4">
        <% if @scorecard.present? %>
          <%= render "analysis", scorecard: @scorecard, run: @analysis_run, legality: @legality, recommendations: @scorecard.improvement_suggestions %>
        <% else %>
          <p class="text-sm text-zinc-400">No deterministic run is recorded.</p>
        <% end %>
      </div>
    </details>
  <% elsif @scorecard.present? %>
    <%= render "analysis", scorecard: @scorecard, run: @analysis_run, legality: @legality, recommendations: @recommendations %>
    <p class="text-xs text-zinc-500">
      This is a preliminary deterministic read. Run the AI evaluation below for a deeper, deckcheck-style review that scores this deck against the official Commander Brackets and rewrites these numbers.
    </p>
  <% else %>
    <div class="rounded-md border border-zinc-800 bg-zinc-900 p-4 text-sm text-zinc-300">
      Deterministic analysis has not run for this deck yet.
    </div>
  <% end %>

  <%= render "codex/ai_evaluation",
      run: @ai_run,
      enqueue_path: deck_ai_evaluation_path(@deck),
      title: "AI deck evaluation",
      target_label: "deck",
      codex_account: @codex_account,
      authoritative: true %>

  <div class="rounded-lg border border-zinc-800 bg-zinc-900 p-5">
    <div class="flex flex-wrap items-baseline justify-between gap-3">
      <div>
        <h2 class="text-lg font-medium text-white">Table performance</h2>
        <p class="mt-1 text-sm text-zinc-400">
          Results come from completed game-night pods. Confidence stays visible so thin samples stay honest.
        </p>
      </div>
      <span class="rounded-md bg-zinc-800 px-2.5 py-1 text-xs font-medium text-zinc-300"><%= @deck_performance.confidence_label %></span>
    </div>

    <% if @deck_performance.games.zero? %>
      <p class="mt-4 text-sm text-zinc-400">No recorded games for this deck yet.</p>
    <% else %>
      <dl class="mt-4 grid gap-3 text-sm sm:grid-cols-2 lg:grid-cols-5">
        <div class="rounded-md border border-zinc-800 bg-zinc-950 p-3">
          <dt class="text-xs uppercase tracking-wide text-zinc-500">Games</dt>
          <dd class="mt-1 text-lg font-semibold text-white"><%= @deck_performance.games %></dd>
        </div>
        <div class="rounded-md border border-zinc-800 bg-zinc-950 p-3">
          <dt class="text-xs uppercase tracking-wide text-zinc-500">Record</dt>
          <dd class="mt-1 text-lg font-semibold text-white"><%= @deck_performance.wins %>-<%= @deck_performance.losses %>-<%= @deck_performance.draws %></dd>
        </div>
        <div class="rounded-md border border-zinc-800 bg-zinc-950 p-3">
          <dt class="text-xs uppercase tracking-wide text-zinc-500">Win rate</dt>
          <dd class="mt-1 text-lg font-semibold text-white"><%= number_to_percentage(@deck_performance.win_rate.to_f * 100, precision: 0) %></dd>
        </div>
        <div class="rounded-md border border-zinc-800 bg-zinc-950 p-3">
          <dt class="text-xs uppercase tracking-wide text-zinc-500">Avg turns</dt>
          <dd class="mt-1 text-lg font-semibold text-white"><%= @deck_performance.average_turns ? number_with_precision(@deck_performance.average_turns, precision: 1) : "n/a" %></dd>
        </div>
        <div class="rounded-md border border-zinc-800 bg-zinc-950 p-3">
          <dt class="text-xs uppercase tracking-wide text-zinc-500">Last played</dt>
          <dd class="mt-1 text-lg font-semibold text-white"><%= @deck_performance.last_played_on&.to_fs(:medium) || "n/a" %></dd>
        </div>
      </dl>
    <% end %>

    <% if @revision_performance.any? %>
      <div class="mt-5 overflow-x-auto">
        <table class="min-w-full divide-y divide-zinc-800 text-sm">
          <thead>
            <tr class="text-left text-xs uppercase tracking-wide text-zinc-500">
              <th class="py-2 pr-4 font-medium">Revision snapshot</th>
              <th class="py-2 pr-4 font-medium">Cards</th>
              <th class="py-2 pr-4 font-medium">Games</th>
              <th class="py-2 pr-4 font-medium">Record</th>
              <th class="py-2 pr-4 font-medium">Win rate</th>
              <th class="py-2 font-medium">Last played</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-zinc-800 text-zinc-300">
            <% @revision_performance.each do |revision| %>
              <tr>
                <td class="py-2 pr-4"><%= revision.deck_updated_at.present? ? Time.zone.parse(revision.deck_updated_at).to_fs(:short) : "Unknown" %></td>
                <td class="py-2 pr-4"><%= revision.deck_card_count || "n/a" %></td>
                <td class="py-2 pr-4"><%= revision.stats.games %></td>
                <td class="py-2 pr-4"><%= revision.stats.wins %>-<%= revision.stats.losses %>-<%= revision.stats.draws %></td>
                <td class="py-2 pr-4"><%= number_to_percentage(revision.stats.win_rate.to_f * 100, precision: 0) %></td>
                <td class="py-2"><%= revision.stats.last_played_on&.to_fs(:medium) || "n/a" %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% end %>
  </div>

  <div class="rounded-lg border border-zinc-800 bg-zinc-900 p-5">
    <div class="flex flex-wrap items-baseline justify-between gap-3">
      <div>
        <h2 class="text-lg font-medium text-white">Collection fit</h2>
        <p class="mt-1 text-sm text-zinc-400">
          <%= @ownership.owned_count %>/<%= @ownership.required_count %> cards owned
          <% if @ownership.missing_count.positive? %>
            · <%= @ownership.missing_count %> missing
          <% else %>
            · ready from your collection
          <% end %>
        </p>
      </div>
      <%= link_to "Manage collection", collection_path, class: "rounded-md bg-zinc-800 px-3 py-2 text-sm font-medium text-white hover:bg-zinc-700" %>
    </div>
    <% if @ownership.entries.empty? %>
      <p class="mt-4 text-sm text-zinc-400">No deck cards recorded yet.</p>
    <% elsif @ownership.missing_entries.any? %>
      <ul class="mt-4 grid gap-2 text-sm sm:grid-cols-2 lg:grid-cols-3">
        <% @ownership.missing_entries.first(24).each do |entry| %>
          <li class="rounded-md border border-zinc-800 bg-zinc-950 p-3">
            <p class="font-medium text-zinc-100"><%= entry.name %></p>
            <p class="mt-1 text-xs text-zinc-500">
              Own <%= entry.owned_quantity %> · Need <%= entry.required_quantity %> · Missing <%= entry.missing_quantity %>
            </p>
          </li>
        <% end %>
      </ul>
      <% if @ownership.missing_entries.size > 24 %>
        <p class="mt-3 text-xs text-zinc-500">Showing first 24 missing cards.</p>
      <% end %>
    <% else %>
      <p class="mt-4 text-sm text-emerald-200">Every recorded card in this deck is covered by your collection.</p>
    <% end %>
  </div>

  <div class="grid gap-6 lg:grid-cols-2">
    <% if @deck.commanders.any? %>
      <div class="rounded-lg border border-zinc-800 bg-zinc-900 p-5">
        <h2 class="text-lg font-medium text-white">Commander</h2>
        <ul class="mt-3 space-y-1 text-sm text-zinc-200">
          <% @deck.commanders.order(:position).each do |commander| %>
            <li><%= commander.name %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <% DeckCard::BOARDS.each do |board| %>
      <% cards = @deck.deck_cards.where(board: board).order(:position, :name) %>
      <% next if cards.empty? %>
      <div class="rounded-lg border border-zinc-800 bg-zinc-900 p-5">
        <h2 class="text-lg font-medium text-white"><%= board.humanize %> · <%= cards.sum(&:quantity) %> cards</h2>
        <ul class="mt-3 grid gap-1 text-sm text-zinc-200 sm:grid-cols-2">
          <% cards.each do |card| %>
            <li><span class="text-zinc-500"><%= card.quantity %>×</span> <%= card.name %></li>
          <% end %>
        </ul>
      </div>
    <% end %>
  </div>
</section>
