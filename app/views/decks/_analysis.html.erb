<%
  scorecard ||= nil
  run ||= nil
  legality ||= nil

  evidence = scorecard.evidence.is_a?(Hash) ? scorecard.evidence : {}
  recs = local_assigns.fetch(:recommendations, Array(scorecard.improvement_suggestions))
  bracket = scorecard.bracket_payload.is_a?(Hash) ? scorecard.bracket_payload : {}

  score_specs = [
    { key: "power", label: "Power", value: scorecard.power_score, hint: "Goldfish ceiling: ramp + tutors + combo + draw." },
    { key: "speed", label: "Speed", value: scorecard.speed_score, hint: "How fast the deck wants to act." },
    { key: "interaction", label: "Interaction", value: scorecard.interaction_score, hint: "Removal, counters, wipes, protection." },
    { key: "consistency", label: "Consistency", value: scorecard.consistency_score, hint: "Mana, draw, tutors, fixing." },
    { key: "salt", label: "Salt", value: scorecard.salt_score, hint: "Drivers of resentment at the table. Neutral, not a judgment." },
    { key: "social_friction", label: "Social friction", value: scorecard.social_friction_score, hint: "Table-experience patterns separate from raw power." }
  ]
%>

<section class="space-y-4" data-testid="deck-analysis">
  <header class="flex flex-wrap items-baseline justify-between gap-3">
    <div>
      <h2 class="text-lg font-medium text-white">Deterministic analysis</h2>
      <p class="mt-1 text-xs text-zinc-500">
        Rubric <code class="font-mono"><%= run&.rubric_version || scorecard.raw_payload["rubric_version"] %></code>
        <% if bracket["version"].present? %>
          · Brackets catalog <code class="font-mono"><%= bracket["version"] %></code>
        <% end %>
        <% if scorecard.confidence.present? %>
          · Confidence <%= number_to_percentage(scorecard.confidence.to_f * 100, precision: 0) %>
        <% end %>
        <% if run&.completed_at %>
          · Computed <%= time_ago_in_words(run.completed_at) %> ago
        <% end %>
      </p>
    </div>
  </header>

  <% if scorecard.bracket.present? %>
    <%
      bracket_color = {
        1 => "border-sky-700 bg-sky-950/40 text-sky-100",
        2 => "border-emerald-700 bg-emerald-950/40 text-emerald-100",
        3 => "border-amber-700 bg-amber-950/40 text-amber-100",
        4 => "border-orange-700 bg-orange-950/40 text-orange-100",
        5 => "border-rose-700 bg-rose-950/40 text-rose-100"
      }[scorecard.bracket]
      restrictions = Array(bracket["restrictions"])
      gc_hits = Array(bracket["game_changers"])
      combo_pairs = Array(bracket["combo_pairs"])
      meta_evidence = bracket["evidence"] || {}
    %>

    <article class="rounded-lg border <%= bracket_color %> p-5">
      <header class="flex flex-wrap items-baseline justify-between gap-3">
        <div>
          <p class="text-xs uppercase tracking-wide opacity-80">Commander Brackets</p>
          <h3 class="mt-1 text-2xl font-semibold">
            <%= bracket["headline"] || "Bracket #{scorecard.bracket}" %>
          </h3>
          <p class="mt-1 text-sm opacity-90"><%= bracket["tagline"] %></p>
        </div>
        <div class="text-right text-sm">
          <p class="text-xs uppercase tracking-wide opacity-80">Sub-band</p>
          <p class="mt-1 font-mono text-base"><%= scorecard.bracket_sub_band&.capitalize || "—" %></p>
          <% if bracket["expected_min_turn"].present? %>
            <p class="mt-1 text-xs opacity-80">Expected min turns: <%= bracket["expected_min_turn"] %>+</p>
          <% else %>
            <p class="mt-1 text-xs opacity-80">Any-turn wins permitted</p>
          <% end %>
        </div>
      </header>

      <%= link_to "What does Bracket #{scorecard.bracket} mean?",
          "/brackets##{bracket['label']&.parameterize}",
          class: "mt-3 inline-block text-xs underline opacity-90 hover:opacity-100" %>

      <% if restrictions.any? %>
        <div class="mt-4 grid gap-2 text-sm sm:grid-cols-2">
          <% restrictions.each do |r| %>
            <%
              status = r["status"].to_s
              status_label = {
                "ok" => "OK",
                "ok_singleton" => "OK · single",
                "absent" => "—",
                "any_allowed" => "Any allowed",
                "present_allowed" => "Present (allowed)",
                "violation" => "Violation"
              }[status] || status.humanize
              status_color =
                case status
                when "violation" then "text-rose-300"
                when "ok", "absent", "ok_singleton", "any_allowed", "present_allowed" then "text-emerald-300"
                else "text-zinc-300"
                end
            %>
            <div class="rounded border border-zinc-800/60 bg-zinc-900/40 p-3">
              <div class="flex items-baseline justify-between gap-2">
                <p class="font-medium"><%= r["label"] %></p>
                <p class="text-xs <%= status_color %> font-mono uppercase tracking-wide"><%= status_label %></p>
              </div>
              <p class="mt-1 text-xs opacity-80">
                Allowance: <%= r["allowance"] %> · Found: <%= r["actual"] %>
              </p>
              <% if Array(r["evidence"]).any? %>
                <p class="mt-1 text-xs opacity-70">
                  <%= Array(r["evidence"]).join(", ") %>
                </p>
              <% end %>
            </div>
          <% end %>
        </div>
      <% end %>

      <% if gc_hits.any? %>
        <div class="mt-4">
          <p class="text-xs uppercase tracking-wide opacity-80">Game Changers in this deck (<%= gc_hits.size %>)</p>
          <ul class="mt-1 flex flex-wrap gap-2 text-xs">
            <% gc_hits.each do |gc| %>
              <li class="rounded-full bg-zinc-900/60 px-2.5 py-1 font-mono">
                <%= gc["name"] %>
                <span class="opacity-60">· <%= gc["category"]&.humanize&.downcase %></span>
              </li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <% if combo_pairs.any? %>
        <div class="mt-4">
          <p class="text-xs uppercase tracking-wide opacity-80">Two-card combo lines detected</p>
          <ul class="mt-1 list-disc pl-5 text-sm">
            <% combo_pairs.each do |pair| %>
              <li>
                <%= pair["name"] %>
                <% if pair["wins_immediately"] %>
                  <span class="text-rose-300">· wins immediately</span>
                <% end %>
              </li>
            <% end %>
          </ul>
        </div>
      <% end %>
    </article>
  <% end %>

  <details class="rounded-lg border border-zinc-800 bg-zinc-900/60">
    <summary class="cursor-pointer list-none px-4 py-3 text-sm font-medium text-white">
      Sub-band evidence — six-axis scorecard
      <span class="ml-2 text-xs text-zinc-500">(0–10 axes that place the deck inside its bracket)</span>
    </summary>
    <ul class="grid gap-3 p-4 sm:grid-cols-2 lg:grid-cols-3">
      <% score_specs.each do |spec| %>
        <% score_block = evidence[spec[:key]] || {} %>
        <% score_evidence = score_block["evidence"] || {} %>
        <li class="rounded-lg border border-zinc-800 bg-zinc-900 p-4">
          <details class="group">
            <summary class="flex cursor-pointer list-none items-baseline justify-between gap-3">
              <div>
                <p class="text-xs uppercase tracking-wide text-zinc-400"><%= spec[:label] %></p>
                <p class="mt-1 text-2xl font-semibold text-white"><%= spec[:value] || "—" %><span class="text-sm text-zinc-500">/10</span></p>
              </div>
              <span class="text-xs text-emerald-300 group-open:hidden">Evidence ▸</span>
              <span class="text-xs text-emerald-300 hidden group-open:inline">Hide ▾</span>
            </summary>
            <p class="mt-2 text-xs text-zinc-500"><%= spec[:hint] %></p>
            <div class="mt-3 space-y-2 text-xs text-zinc-300">
              <%= render "decks/score_evidence", key: spec[:key], data: score_evidence %>
            </div>
          </details>
        </li>
      <% end %>
    </ul>
  </details>

  <% if legality.present? %>
    <% issues = Array(legality["issues"]) %>
    <% legal = legality["legal"] %>
    <div class="rounded-lg border <%= legal ? 'border-emerald-800 bg-emerald-950/30' : 'border-amber-800 bg-amber-950/30' %> p-4 text-sm">
      <p class="font-medium <%= legal ? 'text-emerald-200' : 'text-amber-200' %>">
        Commander legality:
        <%= legal ? "Legal" : "Issues found" %>
      </p>
      <% if legality["snapshot_effective_on"].present? %>
        <p class="mt-1 text-xs text-zinc-400">
          Snapshot <%= legality["snapshot_source"] %> · effective <%= legality["snapshot_effective_on"] %>
        </p>
      <% end %>
      <% if issues.any? %>
        <ul class="mt-3 space-y-1 text-xs">
          <% issues.first(20).each do |issue| %>
            <li class="flex gap-2">
              <span class="font-mono uppercase text-zinc-500"><%= issue["severity"] %></span>
              <span class="text-zinc-200">
                <%= issue["message"] %>
                <% if issue["card_name"].present? %>
                  <span class="text-zinc-500">(<%= issue["card_name"] %>)</span>
                <% end %>
              </span>
            </li>
          <% end %>
        </ul>
      <% end %>
    </div>
  <% end %>

  <% if recs.any? %>
    <div class="rounded-lg border border-zinc-800 bg-zinc-900 p-4">
      <h3 class="text-sm font-medium text-white">Suggestions</h3>
      <ul class="mt-2 space-y-2 text-sm text-zinc-200">
        <% recs.each do |rec| %>
          <% ownership = rec["ownership"] || {} %>
          <li class="flex flex-col">
            <span class="font-medium"><%= rec["title"] %></span>
            <span class="text-xs text-zinc-400"><%= rec["detail"] %></span>
            <% if ownership.any? %>
              <span class="mt-1 text-xs <%= ownership["status"] == "owned_options" ? "text-emerald-300" : "text-amber-300" %>">
                <%= ownership["label"] %> · <%= ownership["detail"] %>
              </span>
            <% end %>
          </li>
        <% end %>
      </ul>
    </div>
  <% end %>
</section>
