<% content_for :title, "#{@deck.name} (shared deck)" %>
<%
  meta_bracket =
    if @ai_evaluation&.bracket_value
      "Bracket #{@ai_evaluation.bracket_value} · AI evaluation"
    elsif @scorecard&.bracket
      "Bracket #{@scorecard.bracket} · deterministic preliminary read"
    end
  meta_summary =
    if @ai_evaluation&.summary.present?
      @ai_evaluation.summary
    else
      @deck.commander_names.join(", ").presence
    end
  meta = [ meta_bracket, meta_summary ].compact.reject(&:empty?).join(" · ")
%>
<% if meta.present? %>
  <% content_for :meta_description, meta %>
<% end %>

<section class="space-y-6">
  <div class="space-y-2">
    <p class="text-xs uppercase tracking-wide text-emerald-300">Shared Commander deck</p>
    <h1 class="text-2xl font-semibold text-white print:text-zinc-900"><%= @deck.name %></h1>
    <p class="text-sm text-zinc-400 print:text-zinc-700">
      <%= @deck.commander_names.join(", ").presence || "No commander recorded" %>
      · <%= pluralize(@deck.deck_cards.sum(:quantity), "card") %>
      <% if @deck.shared_at.present? %>
        · Shared <%= time_ago_in_words(@deck.shared_at) %> ago
      <% end %>
      <% if @ai_evaluation&.completed_at.present? %>
        · AI evaluated <%= time_ago_in_words(@ai_evaluation.completed_at) %> ago
      <% elsif @analysis_run&.completed_at %>
        · Analyzed <%= time_ago_in_words(@analysis_run.completed_at) %> ago
      <% end %>
    </p>
    <p class="text-xs text-zinc-500 print:text-zinc-700">
      Public read-only view of this deck. Decklist, Commander Brackets analysis, and Commander legality only —
      no playgroup notes, table results, collection data, or owner identity are exposed.
    </p>
  </div>

  <div class="rounded-lg border border-zinc-800 bg-zinc-900/60 p-4 print:hidden"
       data-controller="copy-link"
       data-copy-link-url-value="<%= public_deck_url(@deck.share_token) %>">
    <div class="flex flex-wrap items-baseline justify-between gap-3">
      <div>
        <h2 class="text-sm font-medium text-white">Share &amp; download</h2>
        <p class="mt-1 text-xs text-zinc-500">
          Share the link or grab the decklist and analysis as a file.
        </p>
        <p class="mt-2 break-all font-mono text-xs text-zinc-400">
          <%= public_deck_url(@deck.share_token) %>
        </p>
      </div>
      <div class="flex flex-wrap gap-2 text-xs">
        <button type="button"
                data-action="copy-link#copy"
                data-copy-link-target="button"
                class="rounded-md bg-emerald-600 px-2.5 py-1.5 font-medium text-white hover:bg-emerald-500">
          Copy link
        </button>
        <span class="text-zinc-500 self-center">Decklist:</span>
        <%= link_to "Text", public_deck_export_path(@deck.share_token, format: :text), class: "rounded-md border border-zinc-700 px-2.5 py-1.5 font-medium text-zinc-200 hover:bg-zinc-800" %>
        <%= link_to "CSV", public_deck_export_path(@deck.share_token, format: :csv), class: "rounded-md border border-zinc-700 px-2.5 py-1.5 font-medium text-zinc-200 hover:bg-zinc-800" %>
        <%= link_to "JSON", public_deck_export_path(@deck.share_token, format: :json), class: "rounded-md border border-zinc-700 px-2.5 py-1.5 font-medium text-zinc-200 hover:bg-zinc-800" %>
        <% if @scorecard.present? || @ai_evaluation.present? %>
          <span class="ml-2 text-zinc-500 self-center">Analysis:</span>
          <%= link_to "Markdown", public_deck_analysis_path(@deck.share_token, format: :markdown), class: "rounded-md border border-zinc-700 px-2.5 py-1.5 font-medium text-zinc-200 hover:bg-zinc-800" %>
          <%= link_to "JSON", public_deck_analysis_path(@deck.share_token, format: :json), class: "rounded-md border border-zinc-700 px-2.5 py-1.5 font-medium text-zinc-200 hover:bg-zinc-800" %>
        <% end %>
      </div>
    </div>
  </div>

  <% if @ai_evaluation.present? %>
    <%= render "decks/ai_analysis", evaluation: @ai_evaluation, legality: @legality, recommendations: @recommendations %>

    <% if @scorecard.present? %>
      <details class="rounded-lg border border-zinc-800 bg-zinc-900/40">
        <summary class="cursor-pointer list-none px-4 py-3 text-sm font-medium text-zinc-300">
          Show preliminary deterministic read
          <span class="ml-2 text-xs text-zinc-500">(used before AI evaluation; AI is now authoritative)</span>
        </summary>
        <div class="border-t border-zinc-800 p-4">
          <%= render "decks/analysis", scorecard: @scorecard, run: @analysis_run, legality: @legality, recommendations: Array(@scorecard.improvement_suggestions) %>
        </div>
      </details>
    <% end %>
  <% elsif @scorecard.present? %>
    <%= render "decks/analysis", scorecard: @scorecard, run: @analysis_run, legality: @legality, recommendations: @recommendations %>
  <% else %>
    <div class="rounded-md border border-zinc-800 bg-zinc-900 p-4 text-sm text-zinc-300">
      Deterministic analysis has not run for this deck yet.
    </div>
  <% end %>

  <div class="grid gap-6 lg:grid-cols-2">
    <% if @deck.commanders.any? %>
      <div class="rounded-lg border border-zinc-800 bg-zinc-900 p-5">
        <h2 class="text-lg font-medium text-white">Commander</h2>
        <ul class="mt-3 space-y-1 text-sm text-zinc-200">
          <% @deck.commanders.order(:position).each do |commander| %>
            <li><%= commander.name %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <% DeckCard::BOARDS.each do |board| %>
      <% cards = @deck.deck_cards.where(board: board).order(:position, :name) %>
      <% next if cards.empty? %>
      <div class="rounded-lg border border-zinc-800 bg-zinc-900 p-5">
        <h2 class="text-lg font-medium text-white"><%= board.humanize %> · <%= cards.sum(&:quantity) %> cards</h2>
        <ul class="mt-3 grid gap-1 text-sm text-zinc-200 sm:grid-cols-2">
          <% cards.each do |card| %>
            <li><span class="text-zinc-500"><%= card.quantity %>×</span> <%= card.name %></li>
          <% end %>
        </ul>
      </div>
    <% end %>
  </div>

  <p class="rounded-md border border-zinc-800 bg-zinc-900/40 p-4 text-xs text-zinc-500 print:hidden">
    Want to evaluate your own Commander deck like this? <%= link_to "Try Pod Tracker", root_path, class: "underline hover:text-zinc-300" %>.
  </p>
</section>
