<section class="grid w-full gap-6 lg:grid-cols-[minmax(0,1fr)_24rem]">
  <div class="space-y-6">
    <div class="space-y-3">
      <p class="text-sm font-medium uppercase tracking-wide text-emerald-300">Commander analysis workspace</p>
      <h1 class="text-3xl font-semibold text-white sm:text-4xl">Pod Tracker</h1>
      <p class="max-w-2xl text-base leading-7 text-zinc-300">
        Import Commander decks, run deterministic checks, and build evidence-backed pod evaluations.
      </p>
    </div>

    <div class="rounded-lg border border-zinc-800 bg-zinc-900 p-5">
      <h2 class="text-lg font-medium text-white">Deck intake</h2>
      <p class="mt-2 text-sm leading-6 text-zinc-400">
        Import Commander decks, track owned cards, compare pods, and start a game-night session when players arrive.
      </p>
      <div class="mt-4 flex flex-wrap gap-3">
        <%= link_to "Import a deck", new_deck_path, class: "rounded-md bg-emerald-600 px-3.5 py-2.5 text-sm font-medium text-white hover:bg-emerald-500" %>
        <%= link_to "View your decks", decks_path, class: "rounded-md bg-zinc-800 px-3.5 py-2.5 text-sm font-medium text-white hover:bg-zinc-700" %>
        <%= link_to "Manage collection", collection_path, class: "rounded-md bg-zinc-800 px-3.5 py-2.5 text-sm font-medium text-white hover:bg-zinc-700" %>
        <%= link_to "Build a pod", new_pod_path, class: "rounded-md bg-zinc-800 px-3.5 py-2.5 text-sm font-medium text-white hover:bg-zinc-700" %>
        <%= link_to "Start a session", new_game_night_path, class: "rounded-md bg-zinc-800 px-3.5 py-2.5 text-sm font-medium text-white hover:bg-zinc-700" %>
        <%= link_to "Open journal", matchup_notes_path, class: "rounded-md bg-zinc-800 px-3.5 py-2.5 text-sm font-medium text-white hover:bg-zinc-700" %>
      </div>
    </div>

    <div class="rounded-lg border border-zinc-800 bg-zinc-900 p-5">
      <div class="flex flex-wrap items-baseline justify-between gap-3">
        <div>
          <h2 class="text-lg font-medium text-white">Commander meta</h2>
          <p class="mt-1 text-sm text-zinc-400">Appearances and wins from completed game-night pods. Thin samples are labeled.</p>
        </div>
        <%= link_to "Sessions", game_nights_path, class: "text-sm font-medium text-emerald-300 hover:text-emerald-200" %>
      </div>

      <% if @commander_meta.empty? %>
        <p class="mt-4 text-sm text-zinc-400">Record session results to start seeing commander trends.</p>
      <% else %>
        <div class="mt-4 overflow-x-auto">
          <table class="min-w-full divide-y divide-zinc-800 text-sm">
            <thead>
              <tr class="text-left text-xs uppercase tracking-wide text-zinc-500">
                <th class="py-2 pr-4 font-medium">Commander</th>
                <th class="py-2 pr-4 font-medium">Games</th>
                <th class="py-2 pr-4 font-medium">Wins</th>
                <th class="py-2 pr-4 font-medium">Win rate</th>
                <th class="py-2 pr-4 font-medium">Avg turns</th>
                <th class="py-2 font-medium">Signal</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-zinc-800 text-zinc-300">
              <% @commander_meta.each do |commander| %>
                <tr>
                  <td class="py-2 pr-4 font-medium text-zinc-100"><%= commander.name %></td>
                  <td class="py-2 pr-4"><%= commander.games %></td>
                  <td class="py-2 pr-4"><%= commander.wins %><% if commander.draws.positive? %> · <%= commander.draws %> draws<% end %></td>
                  <td class="py-2 pr-4"><%= number_to_percentage(commander.win_rate.to_f * 100, precision: 0) %></td>
                  <td class="py-2 pr-4"><%= commander.average_turns ? number_with_precision(commander.average_turns, precision: 1) : "n/a" %></td>
                  <td class="py-2"><%= commander.confidence_label %> · <%= commander.trend_label %></td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% end %>
    </div>
  </div>

  <aside class="rounded-lg border border-zinc-800 bg-zinc-900 p-5">
    <h2 class="text-lg font-medium text-white">Foundation status</h2>
    <dl class="mt-4 space-y-3 text-sm">
      <div class="flex items-center justify-between gap-4">
        <dt class="text-zinc-400">Rails</dt>
        <dd class="font-medium text-zinc-100"><%= Rails.version %></dd>
      </div>
      <div class="flex items-center justify-between gap-4">
        <dt class="text-zinc-400">Ruby</dt>
        <dd class="font-medium text-zinc-100"><%= RUBY_VERSION %></dd>
      </div>
      <div class="flex items-center justify-between gap-4">
        <dt class="text-zinc-400">Database</dt>
        <dd class="font-medium text-zinc-100">PostgreSQL</dd>
      </div>
    </dl>
  </aside>
</section>
