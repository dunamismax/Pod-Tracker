<div class="mx-auto md:w-2/3 w-full">
  <% if notice = flash[:notice] %>
    <p class="py-2 px-3 bg-green-50 mb-5 text-green-500 font-medium rounded-lg inline-block" id="notice"><%= notice %></p>
  <% end %>
  <% if alert = flash[:alert] %>
    <p class="py-2 px-3 bg-red-50 mb-5 text-red-500 font-medium rounded-lg inline-block" id="alert"><%= alert %></p>
  <% end %>

  <h1 class="font-bold text-4xl">Account</h1>

  <dl class="my-6 space-y-3 text-sm">
    <div class="flex justify-between gap-4">
      <dt class="text-zinc-400">Email</dt>
      <dd class="font-medium text-zinc-100"><%= @user.email_address %></dd>
    </div>
    <div class="flex justify-between gap-4">
      <dt class="text-zinc-400">Display name</dt>
      <dd class="font-medium text-zinc-100"><%= @user.display_name.presence || "(not set)" %></dd>
    </div>
    <div class="flex justify-between gap-4">
      <dt class="text-zinc-400">Timezone</dt>
      <dd class="font-medium text-zinc-100"><%= @user.timezone %></dd>
    </div>
    <div class="flex justify-between gap-4">
      <dt class="text-zinc-400">Preferred units</dt>
      <dd class="font-medium text-zinc-100"><%= @user.preferred_units.titleize %></dd>
    </div>
    <div class="flex justify-between gap-4">
      <dt class="text-zinc-400">Email verified</dt>
      <dd class="font-medium text-zinc-100">
        <% if @user.email_verified? %>
          Verified <%= time_ago_in_words(@user.email_verified_at) %> ago
        <% else %>
          <%= button_to "Send verification email", email_verifications_path, method: :post, class: "rounded bg-blue-600 hover:bg-blue-500 px-3 py-1.5 text-white" %>
        <% end %>
      </dd>
    </div>
  </dl>

  <h2 class="font-bold text-2xl mt-10">Codex account</h2>

  <% if @codex_account&.connected? %>
    <dl class="my-4 space-y-3 text-sm">
      <div class="flex justify-between gap-4">
        <dt class="text-zinc-400">Status</dt>
        <dd class="font-medium text-zinc-100"><%= @codex_account.status.humanize %></dd>
      </div>
      <div class="flex justify-between gap-4">
        <dt class="text-zinc-400">Auth mode</dt>
        <dd class="font-medium text-zinc-100"><%= @codex_account.auth_mode.humanize %></dd>
      </div>
      <% if @codex_account.displayed_email.present? %>
        <div class="flex justify-between gap-4">
          <dt class="text-zinc-400">ChatGPT account</dt>
          <dd class="font-medium text-zinc-100"><%= @codex_account.displayed_email %></dd>
        </div>
      <% end %>
      <% if @codex_account.plan_type.present? %>
        <div class="flex justify-between gap-4">
          <dt class="text-zinc-400">Plan</dt>
          <dd class="font-medium text-zinc-100"><%= @codex_account.plan_type %></dd>
        </div>
      <% end %>
      <% if @codex_account.last_synced_at.present? %>
        <div class="flex justify-between gap-4">
          <dt class="text-zinc-400">Last synced</dt>
          <dd class="font-medium text-zinc-100"><%= time_ago_in_words(@codex_account.last_synced_at) %> ago</dd>
        </div>
      <% end %>
    </dl>
    <div class="flex flex-wrap gap-3 text-sm">
      <%= button_to "Refresh status", refresh_account_codex_account_path, method: :post, class: "rounded-md px-3.5 py-2.5 bg-blue-600 hover:bg-blue-500 text-white font-medium cursor-pointer" %>
      <%= button_to "Sign out of Codex", logout_account_codex_account_path, method: :post, data: { turbo_confirm: "Sign out of Codex on the App Server and clear stored credentials?" }, class: "rounded-md px-3.5 py-2.5 bg-zinc-800 hover:bg-zinc-700 text-white font-medium cursor-pointer" %>
      <%= button_to "Disconnect locally", account_codex_account_path, method: :delete, data: { turbo_confirm: "Disconnect this Codex account locally? Stored credentials will be erased." }, class: "rounded-md px-3.5 py-2.5 bg-zinc-800 hover:bg-zinc-700 text-white font-medium cursor-pointer" %>
    </div>
  <% elsif @active_codex_login.present? %>
    <p class="my-4 text-sm text-zinc-400">A Codex sign-in is in progress.</p>
    <%= link_to "Continue sign-in", account_codex_login_path(@active_codex_login), class: "rounded-md px-3.5 py-2.5 bg-blue-600 hover:bg-blue-500 text-white font-medium" %>
  <% else %>
    <p class="my-4 text-sm text-zinc-400">
      <% if @codex_account&.disconnected? %>
        Your Codex account is disconnected. Reconnect to enable AI evaluation.
      <% else %>
        No Codex account is connected. AI evaluation requires connecting a ChatGPT/Codex account through the documented Codex App Server flow. Ideal Magic never collects ChatGPT passwords or stores OpenAI API keys in your browser.
      <% end %>
    </p>
    <%= link_to "Connect Codex account", new_account_codex_login_path, class: "rounded-md px-3.5 py-2.5 bg-blue-600 hover:bg-blue-500 text-white font-medium" %>
  <% end %>

  <h2 class="font-bold text-2xl mt-10">AI evaluation availability</h2>
  <p class="my-3 text-sm text-zinc-400">
    Daily caps protect both your account and the shared Codex rate-limit budget. Expected analysis runtimes are estimates from the deterministic plus AI pipeline, not promises.
  </p>
  <% if @analysis_quota %>
    <dl class="my-4 space-y-3 text-sm">
      <div class="flex justify-between gap-4">
        <dt class="text-zinc-400">Your daily AI analyses</dt>
        <dd class="font-medium text-zinc-100">
          <%= @analysis_quota.user_used %> of <%= @analysis_quota.user_limit %> used
          (<%= @analysis_quota.user_remaining %> remaining)
        </dd>
      </div>
      <div class="flex justify-between gap-4">
        <dt class="text-zinc-400">Site-wide daily AI analyses</dt>
        <dd class="font-medium text-zinc-100">
          <%= @analysis_quota.global_used %> of <%= @analysis_quota.global_limit %> used
        </dd>
      </div>
      <div class="flex justify-between gap-4">
        <dt class="text-zinc-400">Expected runtime</dt>
        <dd class="font-medium text-zinc-100">~<%= @analysis_quota.expected_runtime_seconds %> seconds per AI analysis</dd>
      </div>
      <div class="flex justify-between gap-4">
        <dt class="text-zinc-400">Codex rate limit</dt>
        <dd class="font-medium text-zinc-100"><%= @analysis_quota.rate_limit_summary %></dd>
      </div>
      <% if @analysis_quota.blocked? %>
        <div class="flex justify-between gap-4">
          <dt class="text-zinc-400">Status</dt>
          <dd class="font-medium text-amber-300">
            New AI analyses are paused: <%= @analysis_quota.reasons.map { |r| r.to_s.humanize.downcase }.join(", ") %>.
          </dd>
        </div>
      <% else %>
        <div class="flex justify-between gap-4">
          <dt class="text-zinc-400">Status</dt>
          <dd class="font-medium text-emerald-300">Ready to run a new AI analysis.</dd>
        </div>
      <% end %>
    </dl>
  <% end %>

  <h2 class="font-bold text-2xl mt-10">Provider account links</h2>
  <p class="my-3 text-sm text-zinc-400">
    Public deck-host profile links you have recorded. Ideal Magic does not collect provider passwords; deck import still relies on public deck URLs and pasted lists.
  </p>

  <% if @provider_links.any? %>
    <ul class="my-4 divide-y divide-zinc-800 text-sm">
      <% @provider_links.each do |link| %>
        <li class="py-3 flex items-start justify-between gap-4">
          <div>
            <p class="font-medium text-zinc-100"><%= link.provider_label %> · <%= link.handle %></p>
            <p class="text-zinc-400 break-all"><%= link.profile_url %></p>
            <% if link.label.present? %>
              <p class="text-zinc-500 text-xs mt-1"><%= link.label %></p>
            <% end %>
          </div>
          <%= button_to "Remove", account_provider_link_path(link), method: :delete, data: { turbo_confirm: "Remove this provider link?" }, class: "shrink-0 rounded-md px-3 py-1.5 bg-zinc-800 hover:bg-zinc-700 text-white font-medium cursor-pointer" %>
        </li>
      <% end %>
    </ul>
  <% else %>
    <p class="my-4 text-sm text-zinc-500">No provider account links recorded yet.</p>
  <% end %>

  <%= link_to "Add provider link", new_account_provider_link_path, class: "rounded-md px-3.5 py-2.5 bg-blue-600 hover:bg-blue-500 text-white font-medium text-sm" %>

  <h2 class="font-bold text-2xl mt-10">Account actions</h2>
  <div class="mt-4 flex flex-wrap gap-4 text-sm">
    <%= link_to "Edit account", edit_account_path, class: "rounded-md px-3.5 py-2.5 bg-blue-600 hover:bg-blue-500 text-white font-medium" %>
    <%= button_to "Download my data", account_export_path, method: :post, class: "rounded-md px-3.5 py-2.5 bg-zinc-800 hover:bg-zinc-700 text-white font-medium cursor-pointer" %>
    <%= button_to "Sign out", session_path, method: :delete, class: "rounded-md px-3.5 py-2.5 bg-zinc-800 hover:bg-zinc-700 text-white font-medium cursor-pointer" %>
    <%= link_to "Delete account", new_account_deletion_path, class: "rounded-md px-3.5 py-2.5 bg-red-700 hover:bg-red-600 text-white font-medium" %>
  </div>
</div>
