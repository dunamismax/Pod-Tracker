<div class="mx-auto md:w-2/3 w-full">
  <% if alert = flash[:alert] %>
    <p class="py-2 px-3 bg-red-50 mb-5 text-red-500 font-medium rounded-lg inline-block" id="alert"><%= alert %></p>
  <% end %>

  <h1 class="font-bold text-4xl">Edit account</h1>

  <% if @user.errors.any? %>
    <ul class="my-4 text-red-500">
      <% @user.errors.full_messages.each do |message| %>
        <li><%= message %></li>
      <% end %>
    </ul>
  <% end %>

  <%= form_with model: @user, url: account_path, method: :patch, class: "contents" do |form| %>
    <div class="my-5">
      <%= form.label :display_name, class: "block text-sm font-medium text-zinc-100" %>
      <%= form.text_field :display_name, autocomplete: "nickname", maxlength: 60, class: "block shadow-sm rounded-md border border-gray-400 focus:outline-blue-600 px-3 py-2 mt-2 w-full" %>
    </div>

    <div class="my-5">
      <%= form.label :timezone, class: "block text-sm font-medium text-zinc-100" %>
      <%= form.time_zone_select :timezone, ActiveSupport::TimeZone.all, {}, class: "block shadow-sm rounded-md border border-gray-400 focus:outline-blue-600 px-3 py-2 mt-2 w-full text-zinc-900" %>
    </div>

    <div class="my-5">
      <%= form.label :preferred_units, class: "block text-sm font-medium text-zinc-100" %>
      <%= form.select :preferred_units, User::PREFERRED_UNITS.map { |u| [u.titleize, u] }, {}, class: "block shadow-sm rounded-md border border-gray-400 focus:outline-blue-600 px-3 py-2 mt-2 w-full text-zinc-900" %>
    </div>

    <div class="flex gap-4 text-sm">
      <%= form.submit "Save", class: "rounded-md px-3.5 py-2.5 bg-blue-600 hover:bg-blue-500 text-white font-medium cursor-pointer" %>
      <%= link_to "Cancel", account_path, class: "rounded-md px-3.5 py-2.5 bg-zinc-800 hover:bg-zinc-700 text-white font-medium" %>
    </div>
  <% end %>
</div>
