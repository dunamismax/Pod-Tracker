<div class="mx-auto md:w-2/3 w-full">
  <% if notice = flash[:notice] %>
    <p class="py-2 px-3 bg-green-50 mb-5 text-green-500 font-medium rounded-lg inline-block" id="notice"><%= notice %></p>
  <% end %>
  <% if alert = flash[:alert] %>
    <p class="py-2 px-3 bg-red-50 mb-5 text-red-500 font-medium rounded-lg inline-block" id="alert"><%= alert %></p>
  <% end %>

  <h1 class="font-bold text-4xl">Codex sign-in</h1>

  <dl class="my-6 space-y-3 text-sm">
    <div class="flex justify-between gap-4">
      <dt class="text-zinc-400">Method</dt>
      <dd class="font-medium text-zinc-100"><%= @attempt.auth_mode.humanize %></dd>
    </div>
    <div class="flex justify-between gap-4">
      <dt class="text-zinc-400">Status</dt>
      <dd class="font-medium text-zinc-100"><%= @attempt.status.humanize %></dd>
    </div>
    <% if @attempt.expires_at.present? %>
      <div class="flex justify-between gap-4">
        <dt class="text-zinc-400">Expires</dt>
        <dd class="font-medium text-zinc-100"><%= l(@attempt.expires_at, format: :long) %></dd>
      </div>
    <% end %>
  </dl>

  <% case @attempt.status %>
  <% when "awaiting_user" %>
    <% if @attempt.auth_mode == Codex::AccountConnections::BROWSER_AUTH_MODE %>
      <div class="my-6 rounded-md bg-zinc-900/40 p-4">
        <p class="text-sm text-zinc-400">Open this URL on this device to finish ChatGPT sign-in. Ideal Magic never sees your ChatGPT password.</p>
        <% if @attempt.login_url.present? %>
          <p class="mt-3 break-all text-sm">
            <%= link_to @attempt.login_url, @attempt.login_url, class: "text-blue-400 hover:text-blue-300", target: "_blank", rel: "noopener noreferrer" %>
          </p>
        <% else %>
          <p class="mt-3 text-sm text-amber-400">Codex App Server did not return a login URL. Cancel this attempt and try again.</p>
        <% end %>
      </div>
    <% else %>
      <div class="my-6 rounded-md bg-zinc-900/40 p-4">
        <p class="text-sm text-zinc-400">Visit the verification URL on any device, sign in to ChatGPT, and enter the device code below.</p>
        <% if @attempt.verification_uri.present? %>
          <p class="mt-3 break-all text-sm">
            <%= link_to @attempt.verification_uri, @attempt.verification_uri, class: "text-blue-400 hover:text-blue-300", target: "_blank", rel: "noopener noreferrer" %>
          </p>
        <% end %>
        <% if @attempt.user_code.present? %>
          <p class="mt-3 font-mono text-2xl tracking-widest text-zinc-100"><%= @attempt.user_code %></p>
        <% end %>
      </div>
    <% end %>

    <div class="mt-6 flex flex-wrap gap-3 text-sm">
      <%= button_to "Check sign-in status", poll_account_codex_login_path(@attempt), method: :post, class: "rounded-md px-3.5 py-2.5 bg-blue-600 hover:bg-blue-500 text-white font-medium cursor-pointer" %>
      <%= button_to "Cancel sign-in", account_codex_login_path(@attempt), method: :delete, data: { turbo_confirm: "Cancel this Codex sign-in attempt?" }, class: "rounded-md px-3.5 py-2.5 bg-zinc-800 hover:bg-zinc-700 text-white font-medium cursor-pointer" %>
    </div>

  <% when "completed" %>
    <p class="my-4 text-sm text-green-400">Codex account connected. <%= link_to "Back to account", account_path, class: "underline" %>.</p>

  <% when "cancelled", "expired" %>
    <p class="my-4 text-sm text-zinc-400">This sign-in is no longer active.</p>
    <%= link_to "Start a new sign-in", new_account_codex_login_path, class: "rounded-md px-3.5 py-2.5 bg-blue-600 hover:bg-blue-500 text-white font-medium" %>

  <% when "failed" %>
    <p class="my-4 text-sm text-red-400">Codex sign-in failed: <%= @attempt.failure_message.presence || @attempt.failure_code.presence || "unknown error" %></p>
    <%= link_to "Try again", new_account_codex_login_path, class: "rounded-md px-3.5 py-2.5 bg-blue-600 hover:bg-blue-500 text-white font-medium" %>

  <% else %>
    <div class="mt-6 flex flex-wrap gap-3 text-sm">
      <%= button_to "Check sign-in status", poll_account_codex_login_path(@attempt), method: :post, class: "rounded-md px-3.5 py-2.5 bg-blue-600 hover:bg-blue-500 text-white font-medium cursor-pointer" %>
      <%= button_to "Cancel sign-in", account_codex_login_path(@attempt), method: :delete, class: "rounded-md px-3.5 py-2.5 bg-zinc-800 hover:bg-zinc-700 text-white font-medium cursor-pointer" %>
    </div>
  <% end %>

  <div class="mt-8 text-sm">
    <%= link_to "Back to account", account_path, class: "text-zinc-400 hover:text-zinc-200" %>
  </div>
</div>
