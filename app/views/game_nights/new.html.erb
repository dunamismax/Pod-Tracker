<% content_for :title, "Start a session" %>

<section class="mx-auto w-full max-w-4xl space-y-6">
  <div>
    <h1 class="text-2xl font-semibold text-white">Start a session</h1>
    <p class="mt-1 text-sm text-zinc-400">
      Create the game-night record and check players in with the deck each person brought.
    </p>
  </div>

  <% if @decks.empty? %>
    <div class="rounded-md border border-amber-800 bg-amber-950/40 p-4 text-sm text-amber-200">
      Import at least one deck before starting a session. <%= link_to "Import a deck", new_deck_path, class: "underline" %> first.
    </div>
  <% else %>
    <%= form_with model: @form, url: game_nights_path, scope: :game_night_form, local: true, class: "space-y-5", data: { offline_disable: true } do |form| %>
      <% if @form.errors.any? %>
        <div class="rounded-md border border-red-800 bg-red-950/40 p-3 text-sm text-red-200">
          <ul class="list-disc pl-5">
            <% @form.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div class="grid gap-4 sm:grid-cols-2">
        <div>
          <%= form.label :name, "Session name", class: "block text-sm font-medium text-zinc-300" %>
          <%= form.text_field :name, class: "mt-1 block w-full rounded-md border border-zinc-700 bg-zinc-900 px-3 py-2 text-zinc-100", placeholder: "Friday night Commander" %>
        </div>
        <div>
          <%= form.label :played_on, "Date", class: "block text-sm font-medium text-zinc-300" %>
          <%= form.date_field :played_on, class: "mt-1 block w-full rounded-md border border-zinc-700 bg-zinc-900 px-3 py-2 text-zinc-100" %>
        </div>
      </div>

      <div>
        <%= form.label :location, "Location", class: "block text-sm font-medium text-zinc-300" %>
        <%= form.text_field :location, class: "mt-1 block w-full rounded-md border border-zinc-700 bg-zinc-900 px-3 py-2 text-zinc-100", placeholder: "Kitchen table, store name, or Discord" %>
      </div>

      <div>
        <%= form.label :notes, "Notes", class: "block text-sm font-medium text-zinc-300" %>
        <%= form.text_area :notes, rows: 3, class: "mt-1 block w-full rounded-md border border-zinc-700 bg-zinc-900 px-3 py-2 text-zinc-100", placeholder: "House rules, prize notes, or anything to remember later" %>
      </div>

      <fieldset class="space-y-3 rounded-md border border-zinc-800 bg-zinc-950/50 p-4">
        <legend class="px-1 text-sm font-medium text-zinc-300">Player check-in</legend>
        <p class="text-xs text-zinc-500">
          Player names are saved to your account and reused the next time they show up. Pick one owned deck per player for now.
        </p>

        <div class="space-y-3">
          <% @form.check_in_rows.each_with_index do |row, index| %>
            <div class="grid gap-3 rounded-md border border-zinc-800 bg-zinc-900 p-3 sm:grid-cols-[minmax(0,1fr)_minmax(0,1fr)]">
              <div>
                <label for="game_night_form_check_ins_<%= index %>_player_name" class="block text-xs font-medium text-zinc-400">Player</label>
                <%= text_field_tag "game_night_form[check_ins][#{index}][player_name]",
                                   row["player_name"],
                                   id: "game_night_form_check_ins_#{index}_player_name",
                                   autocomplete: "off",
                                   placeholder: "Player name",
                                   class: "mt-1 block w-full rounded-md border border-zinc-700 bg-zinc-950 px-3 py-2 text-sm text-zinc-100" %>
              </div>
              <div>
                <label for="game_night_form_check_ins_<%= index %>_deck_id" class="block text-xs font-medium text-zinc-400">Deck of the night</label>
                <%= select_tag "game_night_form[check_ins][#{index}][deck_id]",
                               options_from_collection_for_select(@decks, :id, :name, row["deck_id"]),
                               id: "game_night_form_check_ins_#{index}_deck_id",
                               include_blank: "Choose a deck",
                               class: "mt-1 block w-full rounded-md border border-zinc-700 bg-zinc-950 px-3 py-2 text-sm text-zinc-100" %>
              </div>
            </div>
          <% end %>
        </div>
      </fieldset>

      <div class="flex flex-wrap gap-3">
        <%= form.submit "Create session", class: "rounded-md bg-emerald-600 px-3.5 py-2.5 text-sm font-medium text-white hover:bg-emerald-500" %>
        <%= link_to "Cancel", game_nights_path, class: "rounded-md bg-zinc-800 px-3.5 py-2.5 text-sm font-medium text-white hover:bg-zinc-700" %>
      </div>
    <% end %>
  <% end %>
</section>
