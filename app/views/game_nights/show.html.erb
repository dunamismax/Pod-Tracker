<% content_for :title, @game_night.name %>

<section class="space-y-6">
  <div class="flex flex-wrap items-start justify-between gap-4">
    <div>
      <p class="text-sm font-medium uppercase tracking-wide text-emerald-300">Game-night session</p>
      <h1 class="mt-1 text-3xl font-semibold text-white"><%= @game_night.name %></h1>
      <p class="mt-2 text-sm text-zinc-400">
        <%= @game_night.played_on.to_fs(:long) %>
        <% if @game_night.location.present? %>
          · <%= @game_night.location %>
        <% end %>
      </p>
    </div>
    <%= button_to "Remove session", game_night_path(@game_night), method: :delete,
                  form: { data: { turbo_confirm: "Remove this session and its check-ins?" } },
                  class: "rounded-md border border-red-900 px-3 py-2 text-sm font-medium text-red-200 hover:bg-red-950/50" %>
  </div>

  <% if @game_night.notes.present? %>
    <div class="rounded-lg border border-zinc-800 bg-zinc-900 p-4">
      <h2 class="text-sm font-medium text-zinc-300">Notes</h2>
      <p class="mt-2 whitespace-pre-line text-sm leading-6 text-zinc-400"><%= @game_night.notes %></p>
    </div>
  <% end %>

  <div class="rounded-lg border border-zinc-800 bg-zinc-900">
    <div class="border-b border-zinc-800 px-5 py-4">
      <h2 class="text-lg font-medium text-white">Roster</h2>
      <p class="mt-1 text-sm text-zinc-500">In-person check-ins and invitees who've already replied. Deck snapshots preserve what each player brought before later edits change a deck.</p>
    </div>
    <% if @checked_in.any? %>
      <ul class="divide-y divide-zinc-800">
        <% @checked_in.each do |check_in| %>
          <% night_deck = @decks_by_player_id[check_in.player_id] %>
          <li class="px-5 py-4">
            <div class="flex flex-wrap items-baseline justify-between gap-4">
              <div>
                <p class="text-base font-medium text-white"><%= check_in.player.name %></p>
                <% if night_deck %>
                  <p class="mt-1 text-sm text-zinc-400">
                    <%= deck_label_for_game_night(night_deck) %>
                    <% if night_deck.commander_names_snapshot.present? %>
                      · <%= night_deck.commander_names_snapshot.join(", ") %>
                    <% end %>
                  </p>
                <% end %>
              </div>
              <span class="text-xs uppercase tracking-wide text-zinc-500">Seat <%= check_in.position %></span>
            </div>
          </li>
        <% end %>
      </ul>
    <% else %>
      <p class="px-5 py-6 text-sm text-zinc-500">No one's confirmed yet. Add an in-person check-in or invite players below.</p>
    <% end %>
  </div>

  <div class="rounded-lg border border-zinc-800 bg-zinc-900">
    <div class="flex flex-wrap items-start justify-between gap-3 border-b border-zinc-800 px-5 py-4">
      <div>
        <h2 class="text-lg font-medium text-white">Invitations</h2>
        <p class="mt-1 text-sm text-zinc-500">Each invitee picks the deck they're bringing. Pending replies don't show up in the roster yet.</p>
      </div>
      <% pending_count = @invitations_by_status["pending"]&.size.to_i %>
      <% accepted_count = @invitations_by_status["accepted"]&.size.to_i %>
      <% declined_count = @invitations_by_status["declined"]&.size.to_i %>
      <div class="flex flex-wrap gap-2 text-xs">
        <% if accepted_count.positive? %>
          <span class="rounded-md bg-emerald-950/60 px-2 py-1 font-medium text-emerald-200"><%= accepted_count %> accepted</span>
        <% end %>
        <% if pending_count.positive? %>
          <span class="rounded-md bg-zinc-800 px-2 py-1 font-medium text-zinc-300"><%= pending_count %> pending</span>
        <% end %>
        <% if declined_count.positive? %>
          <span class="rounded-md bg-zinc-800/60 px-2 py-1 font-medium text-zinc-400"><%= declined_count %> declined</span>
        <% end %>
      </div>
    </div>

    <% if @invitations.any? %>
      <ul class="divide-y divide-zinc-800">
        <% @invitations.each do |invitation| %>
          <li class="px-5 py-4">
            <div class="flex flex-wrap items-baseline justify-between gap-3">
              <div>
                <p class="text-sm font-medium text-white"><%= invitation.display_label %></p>
                <p class="mt-1 text-xs text-zinc-500"><%= invitation.email_address %></p>
                <% if invitation.accepted? && invitation.deck %>
                  <p class="mt-1 text-sm text-zinc-300">
                    Bringing
                    <%= deck_label_for_invitation(invitation) %>
                    <% if invitation.deck.commander_names.present? %>
                      · <%= invitation.deck.commander_names.join(", ") %>
                    <% end %>
                  </p>
                <% elsif invitation.declined? %>
                  <p class="mt-1 text-sm text-zinc-500">
                    Declined
                    <% if invitation.responded_at %>· <%= time_ago_in_words(invitation.responded_at) %> ago<% end %>
                    <% if invitation.response_note.present? %>
                      <span class="block text-xs text-zinc-500">"<%= invitation.response_note %>"</span>
                    <% end %>
                  </p>
                <% elsif invitation.cancelled? %>
                  <p class="mt-1 text-sm text-zinc-500">Cancelled</p>
                <% else %>
                  <p class="mt-1 text-xs text-zinc-500">
                    Invited <%= time_ago_in_words(invitation.invited_at) %> ago<% if invitation.reminded_at %> · reminded <%= time_ago_in_words(invitation.reminded_at) %> ago<% end %>
                  </p>
                <% end %>
              </div>
              <div class="flex flex-wrap items-center gap-2">
                <span class="rounded-md px-2 py-1 text-xs font-medium <%= invitation_badge_classes(invitation.status) %>"><%= invitation.status.titleize %></span>
                <% if invitation.pending? %>
                  <%= button_to "Resend", resend_game_night_invitation_path(@game_night, invitation), method: :post,
                                class: "rounded-md border border-zinc-700 px-2 py-1 text-xs font-medium text-zinc-300 hover:bg-zinc-800",
                                form: { data: { offline_disable: true } } %>
                  <%= button_to "Cancel", game_night_invitation_path(@game_night, invitation), method: :delete,
                                form: { data: { turbo_confirm: "Cancel this invitation?", offline_disable: true } },
                                class: "rounded-md border border-red-900 px-2 py-1 text-xs font-medium text-red-200 hover:bg-red-950/50" %>
                <% end %>
              </div>
            </div>
          </li>
        <% end %>
      </ul>
    <% end %>

    <div class="border-t border-zinc-800 px-5 py-5">
      <h3 class="text-sm font-medium text-white">Invite more players</h3>
      <%= form_with url: game_night_invitations_path(@game_night), method: :post, local: true, class: "mt-3 space-y-3", data: { offline_disable: true } do %>
        <% 3.times do |index| %>
          <div class="grid gap-3 sm:grid-cols-[minmax(0,1fr)_minmax(0,1fr)]">
            <div>
              <label for="invitations_rows_<%= index %>_email_address" class="block text-xs font-medium text-zinc-400">Email</label>
              <%= email_field_tag "invitations[rows][#{index}][email_address]", nil,
                                  id: "invitations_rows_#{index}_email_address",
                                  autocomplete: "off",
                                  placeholder: "podmate@example.com",
                                  class: "mt-1 block w-full rounded-md border border-zinc-700 bg-zinc-950 px-3 py-2 text-sm text-zinc-100" %>
            </div>
            <div>
              <label for="invitations_rows_<%= index %>_display_name" class="block text-xs font-medium text-zinc-400">Display name (optional)</label>
              <%= text_field_tag "invitations[rows][#{index}][display_name]", nil,
                                 id: "invitations_rows_#{index}_display_name",
                                 autocomplete: "off",
                                 placeholder: "First name or nickname",
                                 class: "mt-1 block w-full rounded-md border border-zinc-700 bg-zinc-950 px-3 py-2 text-sm text-zinc-100" %>
            </div>
          </div>
        <% end %>
        <div>
          <label for="invitations_message" class="block text-xs font-medium text-zinc-400">Optional note for invitees</label>
          <%= text_area_tag "invitations[message]", nil, rows: 2, id: "invitations_message",
                            placeholder: "Snacks at 7, first deal at 8.",
                            class: "mt-1 block w-full rounded-md border border-zinc-700 bg-zinc-950 px-3 py-2 text-sm text-zinc-100" %>
          <p class="mt-1 text-xs text-zinc-500">Included in every email sent from this batch.</p>
        </div>
        <%= submit_tag "Send invitations", class: "rounded-md bg-emerald-600 px-3.5 py-2.5 text-sm font-medium text-white hover:bg-emerald-500" %>
      <% end %>
    </div>
  </div>

  <div class="rounded-lg border border-zinc-800 bg-zinc-900">
    <div class="border-b border-zinc-800 px-5 py-4">
      <h2 class="text-lg font-medium text-white">Pod seating</h2>
      <p class="mt-1 text-sm text-zinc-500">
        Suggested pods balance bracket and power scores. Change pod or seat numbers before saving if the table needs a manual override.
      </p>
    </div>

    <%= form_with url: seat_pods_game_night_path(@game_night), method: :post, local: true, class: "space-y-4 p-5", data: { offline_disable: true } do %>
      <div class="space-y-3">
        <% @seating_rows.each_with_index do |row, index| %>
          <% player = @checked_in.detect { |check_in| check_in.player_id.to_s == row["player_id"].to_s }&.player %>
          <% night_deck = @decks_by_player_id[row["player_id"].to_i] %>
          <% next unless player && night_deck %>

          <div class="grid gap-3 rounded-md border border-zinc-800 bg-zinc-950 p-3 sm:grid-cols-[minmax(0,1fr)_7rem_7rem]">
            <div>
              <p class="text-sm font-medium text-white"><%= player.name %></p>
              <p class="mt-1 text-xs text-zinc-500">
                <%= night_deck.deck_name_snapshot %>
                <% if night_deck.commander_names_snapshot.present? %>
                  · <%= night_deck.commander_names_snapshot.join(", ") %>
                <% end %>
              </p>
              <%= hidden_field_tag "seating[rows][#{index}][player_id]", player.id %>
            </div>
            <div>
              <label for="seating_rows_<%= index %>_pod_number" class="block text-xs font-medium text-zinc-400">Pod</label>
              <%= number_field_tag "seating[rows][#{index}][pod_number]", row["pod_number"], min: 1, id: "seating_rows_#{index}_pod_number", autocomplete: "off",
                                   class: "mt-1 block w-full rounded-md border border-zinc-700 bg-zinc-900 px-3 py-2 text-sm text-zinc-100" %>
            </div>
            <div>
              <label for="seating_rows_<%= index %>_seat_number" class="block text-xs font-medium text-zinc-400">Seat</label>
              <%= number_field_tag "seating[rows][#{index}][seat_number]", row["seat_number"], min: 1, id: "seating_rows_#{index}_seat_number", autocomplete: "off",
                                   class: "mt-1 block w-full rounded-md border border-zinc-700 bg-zinc-900 px-3 py-2 text-sm text-zinc-100" %>
            </div>
          </div>
        <% end %>
      </div>

      <%= submit_tag @game_night.game_night_pod_seats.any? ? "Update pods" : "Seat pods",
                     class: "rounded-md bg-emerald-600 px-3.5 py-2.5 text-sm font-medium text-white hover:bg-emerald-500" %>
    <% end %>

    <% if @prior_notes_by_pod.values.any?(&:any?) %>
      <div class="border-t border-zinc-800 px-5 py-5">
        <h3 class="text-sm font-medium text-white">Prior matchup context</h3>
        <p class="mt-1 text-sm text-zinc-500">Recent notes matching the seated decks, commanders, or opponents.</p>

        <div class="mt-4 space-y-3">
          <% @prior_notes_by_pod.each do |pod_number, notes| %>
            <% next if notes.empty? %>
            <section class="rounded-md border border-zinc-800 bg-zinc-950 p-3">
              <h4 class="text-xs font-medium uppercase tracking-wide text-zinc-500">Pod <%= pod_number %></h4>
              <ul class="mt-3 space-y-3">
                <% notes.each do |note| %>
                  <li>
                    <div class="flex flex-wrap items-baseline justify-between gap-2">
                      <%= link_to note.deck.name, matchup_note_path(note), class: "text-sm font-medium text-emerald-300 hover:text-emerald-200" %>
                      <span class="text-xs text-zinc-500"><%= note.happened_at.to_date.to_fs(:medium) %></span>
                    </div>
                    <p class="mt-1 text-xs text-zinc-500">
                      <% if note.commander %><%= note.commander.name %><% end %>
                      <% if note.opponent %><%= note.commander ? " · " : "" %>vs <%= note.opponent.name %><% end %>
                      <% if note.tags.any? %><%= (note.commander || note.opponent) ? " · " : "" %><%= note.tags.join(", ") %><% end %>
                    </p>
                    <p class="mt-1 line-clamp-2 text-sm leading-6 text-zinc-300"><%= note.body %></p>
                  </li>
                <% end %>
              </ul>
            </section>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>

  <% if @pod_seats_by_number.any? %>
    <div class="rounded-lg border border-zinc-800 bg-zinc-900">
      <div class="border-b border-zinc-800 px-5 py-4">
        <h2 class="text-lg font-medium text-white">Session summary</h2>
        <p class="mt-1 text-sm text-zinc-500">Seats keep the deck name, commanders, deck timestamp, and deterministic analysis used when the pod was saved.</p>
      </div>

      <div class="divide-y divide-zinc-800">
        <% @pod_seats_by_number.each do |pod_number, seats| %>
          <% result = @pod_results_by_number[pod_number] %>
          <section class="space-y-4 px-5 py-5">
            <div class="flex flex-wrap items-center justify-between gap-3">
              <h3 class="text-base font-medium text-white">Pod <%= pod_number %></h3>
              <% if result %>
                <span class="rounded-md bg-emerald-950 px-2.5 py-1 text-xs font-medium text-emerald-200">
                  <%= result.draw? ? "Draw" : "#{result.winner_player.name} won" %>
                </span>
              <% else %>
                <span class="rounded-md bg-zinc-800 px-2.5 py-1 text-xs font-medium text-zinc-300">Awaiting result</span>
              <% end %>
            </div>

            <ul class="grid gap-3 sm:grid-cols-2">
              <% seats.each do |seat| %>
                <% scorecard = seat.analysis_snapshot.fetch("scorecard", {}) %>
                <li class="rounded-md border border-zinc-800 bg-zinc-950 p-3">
                  <div class="flex items-start justify-between gap-3">
                    <div>
                      <p class="text-sm font-medium text-white"><%= seat.player.name %></p>
                      <p class="mt-1 text-xs text-zinc-500">
                        <%= deck_label_for_seat(seat) %>
                        <% if seat.commander_names_snapshot.present? %>
                          · <%= seat.commander_names_snapshot.join(", ") %>
                        <% end %>
                      </p>
                    </div>
                    <span class="text-xs uppercase tracking-wide text-zinc-500">Seat <%= seat.seat_number %></span>
                  </div>
                  <% if scorecard["bracket"].present? %>
                    <p class="mt-3 text-xs text-zinc-500">
                      Snapshot: Bracket <%= scorecard["bracket"] %> <%= scorecard["bracket_sub_band"] %>,
                      Power <%= scorecard["power_score"].to_i / 10.0 %>,
                      Speed <%= scorecard["speed_score"].to_i / 10.0 %>
                    </p>
                  <% else %>
                    <p class="mt-3 text-xs text-zinc-600">No deterministic analysis snapshot was available.</p>
                  <% end %>
                </li>
              <% end %>
            </ul>

            <% if result %>
              <p class="text-sm leading-6 text-zinc-400">
                <% if result.turns.present? %>Turns: <%= result.turns %>.<% end %>
                <% if result.win_condition.present? %>Win condition: <%= result.win_condition %>.<% end %>
                <% if result.notes.present? %><span class="block whitespace-pre-line"><%= result.notes %></span><% end %>
              </p>
            <% end %>

            <% host_deck_id = host_owned_deck_id_in_pod(seats) %>
            <% if host_deck_id %>
              <div>
                <%= link_to "Add matchup note for pod #{pod_number}",
                            new_matchup_note_path(game_night_id: @game_night.id, game_night_pod_number: pod_number, deck_id: host_deck_id),
                            class: "text-sm font-medium text-emerald-300 hover:text-emerald-200" %>
              </div>
            <% end %>
          </section>
        <% end %>
      </div>
    </div>

    <div class="rounded-lg border border-zinc-800 bg-zinc-900">
      <div class="border-b border-zinc-800 px-5 py-4">
        <h2 class="text-lg font-medium text-white">Record results</h2>
        <p class="mt-1 text-sm text-zinc-500">Record one outcome per seated pod. Mark a draw instead of choosing a winner when the pod ends without one.</p>
      </div>

      <% if @post_game_prompts.any? %>
        <div class="border-b border-zinc-800 px-5 py-5">
          <h3 class="text-sm font-medium text-white">Post-game prompts</h3>
          <p class="mt-1 text-sm text-zinc-500">Turn fresh results into matchup notes while the table memory is still specific.</p>

          <div class="mt-4 grid gap-3 lg:grid-cols-2">
            <% @post_game_prompts.each do |prompt| %>
              <section class="rounded-md border border-zinc-800 bg-zinc-950 p-3">
                <div class="flex flex-wrap items-baseline justify-between gap-2">
                  <h4 class="text-sm font-medium text-zinc-100"><%= prompt.player_name %> · <%= prompt.deck_name %></h4>
                  <span class="rounded-md bg-zinc-800 px-2 py-1 text-xs text-zinc-300">Pod <%= prompt.pod_number %> · <%= prompt.outcome %></span>
                </div>
                <ul class="mt-3 list-disc space-y-1 pl-5 text-sm leading-6 text-zinc-400">
                  <% prompt.prompts.each do |line| %>
                    <li><%= line %></li>
                  <% end %>
                </ul>
                <%= link_to "Capture note",
                            new_matchup_note_path(game_night_id: @game_night.id, game_night_pod_number: prompt.pod_number, deck_id: prompt.deck.id),
                            class: "mt-3 inline-flex text-sm font-medium text-emerald-300 hover:text-emerald-200" %>
              </section>
            <% end %>
          </div>
        </div>
      <% end %>

      <%= form_with url: pod_results_game_night_path(@game_night), method: :patch, local: true, class: "space-y-5 p-5", data: { offline_disable: true } do %>
        <% @pod_seats_by_number.each_with_index do |(pod_number, seats), index| %>
          <% result = @pod_results_by_number[pod_number] %>
          <fieldset class="space-y-3 rounded-md border border-zinc-800 bg-zinc-950 p-4">
            <legend class="px-1 text-sm font-medium text-zinc-300">Pod <%= pod_number %></legend>
            <%= hidden_field_tag "results[rows][#{index}][pod_number]", pod_number %>

            <div class="grid gap-3 sm:grid-cols-2">
              <div>
                <label for="results_rows_<%= index %>_winner_player_id" class="block text-xs font-medium text-zinc-400">Winner</label>
                <%= select_tag "results[rows][#{index}][winner_player_id]",
                               options_from_collection_for_select(seats.map(&:player), :id, :name, result&.winner_player_id),
                               id: "results_rows_#{index}_winner_player_id",
                               include_blank: "No winner",
                               class: "mt-1 block w-full rounded-md border border-zinc-700 bg-zinc-900 px-3 py-2 text-sm text-zinc-100" %>
              </div>
              <div>
                <label for="results_rows_<%= index %>_turns" class="block text-xs font-medium text-zinc-400">Turns</label>
                <%= number_field_tag "results[rows][#{index}][turns]", result&.turns, min: 1, id: "results_rows_#{index}_turns", autocomplete: "off",
                                     class: "mt-1 block w-full rounded-md border border-zinc-700 bg-zinc-900 px-3 py-2 text-sm text-zinc-100" %>
              </div>
            </div>

            <label class="flex items-center gap-2 text-sm text-zinc-300">
              <%= check_box_tag "results[rows][#{index}][draw]", "1", result&.draw? %>
              Draw
            </label>

            <div>
              <label for="results_rows_<%= index %>_win_condition" class="block text-xs font-medium text-zinc-400">Win condition</label>
              <%= text_field_tag "results[rows][#{index}][win_condition]", result&.win_condition, id: "results_rows_#{index}_win_condition", autocomplete: "off",
                                 placeholder: "Combat damage, combo, concession, mill...",
                                 class: "mt-1 block w-full rounded-md border border-zinc-700 bg-zinc-900 px-3 py-2 text-sm text-zinc-100" %>
            </div>

            <div>
              <label for="results_rows_<%= index %>_notes" class="block text-xs font-medium text-zinc-400">Notes</label>
              <%= text_area_tag "results[rows][#{index}][notes]", result&.notes, rows: 2, id: "results_rows_#{index}_notes",
                                class: "mt-1 block w-full rounded-md border border-zinc-700 bg-zinc-900 px-3 py-2 text-sm text-zinc-100" %>
            </div>
          </fieldset>
        <% end %>

        <%= submit_tag "Save results", class: "rounded-md bg-emerald-600 px-3.5 py-2.5 text-sm font-medium text-white hover:bg-emerald-500" %>
      <% end %>
    </div>
  <% end %>
</section>
