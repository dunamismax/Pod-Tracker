<div class="mx-auto md:w-2/3 w-full">
  <h1 class="font-bold text-3xl">Link a provider account</h1>
  <p class="mt-3 text-sm text-zinc-400">
    Record a link to your public deck-hosting profile. Pod Tracker never asks for, stores, or transmits your provider password. Provider links are placeholders today; deck import still uses public deck URLs and pasted lists until provider sync ships.
  </p>

  <%= form_with model: @provider_link, url: account_provider_links_path, local: true, class: "mt-6 space-y-5" do |form| %>
    <% if @provider_link.errors.any? %>
      <div class="rounded-md bg-red-50 p-3 text-sm text-red-700">
        <ul class="list-disc pl-5">
          <% @provider_link.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div>
      <%= form.label :provider, class: "block text-sm font-medium text-zinc-300" %>
      <%= form.select :provider, UserProviderLink::PROVIDERS.map { |p| [ UserProviderLink::PROVIDER_LABELS.fetch(p, p.humanize), p ] }, { include_blank: "Select a provider" }, class: "mt-1 block w-full rounded-md bg-zinc-900 border border-zinc-700 px-3 py-2 text-zinc-100" %>
    </div>

    <div>
      <%= form.label :handle, "Profile handle", class: "block text-sm font-medium text-zinc-300" %>
      <%= form.text_field :handle, class: "mt-1 block w-full rounded-md bg-zinc-900 border border-zinc-700 px-3 py-2 text-zinc-100", autocomplete: "off" %>
      <p class="mt-1 text-xs text-zinc-500">Your username on the provider — not a password.</p>
    </div>

    <div>
      <%= form.label :profile_url, "Public profile URL", class: "block text-sm font-medium text-zinc-300" %>
      <%= form.url_field :profile_url, class: "mt-1 block w-full rounded-md bg-zinc-900 border border-zinc-700 px-3 py-2 text-zinc-100", placeholder: "https://moxfield.com/users/your-handle" %>
    </div>

    <div>
      <%= form.label :label, "Label (optional)", class: "block text-sm font-medium text-zinc-300" %>
      <%= form.text_field :label, class: "mt-1 block w-full rounded-md bg-zinc-900 border border-zinc-700 px-3 py-2 text-zinc-100" %>
    </div>

    <div>
      <%= form.label :notes, "Notes (optional)", class: "block text-sm font-medium text-zinc-300" %>
      <%= form.text_area :notes, rows: 3, class: "mt-1 block w-full rounded-md bg-zinc-900 border border-zinc-700 px-3 py-2 text-zinc-100" %>
    </div>

    <div class="flex flex-wrap gap-3">
      <%= form.submit "Save provider link", class: "rounded-md px-3.5 py-2.5 bg-blue-600 hover:bg-blue-500 text-white font-medium cursor-pointer" %>
      <%= link_to "Cancel", account_path, class: "rounded-md px-3.5 py-2.5 bg-zinc-800 hover:bg-zinc-700 text-white font-medium" %>
    </div>
  <% end %>
</div>
