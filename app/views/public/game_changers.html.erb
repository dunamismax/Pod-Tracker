<% content_for :title, "Game Changers — Commander Brackets reference" %>
<% content_for :meta_description, "The complete Commander Brackets Game Changers list, grouped by play pattern: fast mana, tutors, engines, prison pieces, finishers, free protection, lands, and metagame commanders." %>
<% site_origin = "#{request.protocol}#{request.host_with_port}" %>
<% content_for :jsonld_extra, jsonld_tag(
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Ideal Magic", "item": "#{site_origin}/" },
    { "@type": "ListItem", "position": 2, "name": "Commander Brackets", "item": "#{site_origin}#{brackets_path}" },
    { "@type": "ListItem", "position": 3, "name": "Game Changers" }
  ]
) %>

<article class="space-y-8">
  <header class="space-y-3">
    <p class="text-xs font-semibold uppercase tracking-[0.18em] text-emerald-300">Bracket reference · Game Changers</p>
    <h1 class="text-3xl font-semibold text-white sm:text-4xl">The Game Changers list</h1>
    <p class="max-w-3xl text-base leading-7 text-zinc-300">
      Game Changers are legal Commander cards that strongly shape the kind of game a deck creates. They are not banned — they are bracket-signaling cards. Brackets 1 and 2 expect zero. Bracket 3 allows up to three. Brackets 4 and 5 allow any number.
    </p>
    <p class="text-xs text-zinc-500">
      <%= @catalog["cards"].size %> cards · catalog version <code class="font-mono"><%= @catalog["version"] %></code> · <a class="underline hover:text-zinc-300" href="<%= brackets_path %>#game-changers">read in context →</a>
    </p>
  </header>

  <section class="grid gap-5 lg:grid-cols-2">
    <% @catalog["categories"].each do |slug, description| %>
      <% group = @catalog["cards"].select { |c| c["category"] == slug } %>
      <% next if group.empty? %>
      <article class="rounded-lg border border-zinc-800 bg-zinc-900/40 p-5">
        <header class="flex items-baseline justify-between gap-3">
          <h2 class="text-lg font-semibold text-white"><%= slug.tr("_", " ").capitalize %></h2>
          <p class="text-xs font-mono text-zinc-500"><%= group.size %> cards</p>
        </header>
        <p class="mt-2 text-sm text-zinc-400"><%= description %></p>
        <ul class="mt-4 space-y-1 text-sm">
          <% group.each do |card| %>
            <li class="flex items-baseline justify-between gap-3 border-t border-zinc-800/60 py-1.5">
              <span class="font-mono text-zinc-100"><%= card["name"] %></span>
            </li>
          <% end %>
        </ul>
      </article>
    <% end %>
  </section>

  <section class="rounded-lg border border-zinc-800 bg-zinc-900/40 p-6 text-sm text-zinc-300">
    <p class="font-medium text-white">A Game Changer makes a deck Bracket 3, not Bracket 4.</p>
    <p class="mt-2">Up to three Game Changers in a deck is a Bracket 3 deck. Crossing four pushes it into Bracket 4. The category is descriptive — fast mana, tutor, engine — not gating.</p>
    <p class="mt-4">
      <%= link_to "Back to the bracket guide", brackets_path, class: "text-emerald-300 hover:text-emerald-200" %>
    </p>
  </section>
</article>
