<% content_for :title, "Collection import" %>

<section class="space-y-6">
  <div class="flex flex-wrap items-end justify-between gap-4">
    <div>
      <p class="text-xs uppercase tracking-wide text-emerald-300">Collection import</p>
      <h1 class="mt-1 text-2xl font-semibold text-white"><%= @collection_import.created_at.to_fs(:long) %></h1>
      <p class="mt-1 text-sm text-zinc-400">
        <%= @collection_import.imported_count %> cards imported · <%= @collection_import.unresolved_count %> unresolved · <%= @collection_import.source_type.humanize %>
      </p>
    </div>
    <%= link_to "Back to collection", collection_path, class: "rounded-md bg-zinc-800 px-3.5 py-2.5 text-sm font-medium text-white hover:bg-zinc-700" %>
  </div>

  <% if @unresolved_entries.empty? %>
    <div class="rounded-lg border border-zinc-800 bg-zinc-900 p-5 text-sm text-zinc-300">
      Every row resolved against the local Scryfall corpus.
    </div>
  <% else %>
    <div class="rounded-lg border border-zinc-800 bg-zinc-900">
      <div class="border-b border-zinc-800 p-5">
        <h2 class="text-lg font-medium text-white">Review unresolved rows</h2>
        <p class="mt-1 text-sm text-zinc-400">Correct the card name to add it, or ignore rows that are not collection cards.</p>
      </div>
      <ul class="divide-y divide-zinc-800">
        <% @unresolved_entries.each do |entry| %>
          <li class="grid gap-3 p-4 lg:grid-cols-[minmax(0,1fr)_22rem] lg:items-center">
            <div>
              <p class="font-medium text-zinc-100"><%= entry.name.presence || entry.raw_line %></p>
              <p class="mt-1 text-sm text-zinc-400"><%= entry.reason %></p>
              <p class="mt-1 text-xs uppercase tracking-wide text-zinc-500">Qty <%= entry.quantity %> · <%= entry.status %></p>
            </div>
            <% if entry.status == "open" %>
              <%= form_with model: entry, url: unresolved_entry_path(entry), method: :patch, local: true, scope: :unresolved_entry, class: "space-y-2" do |form| %>
                <%= form.text_field :name, value: entry.name, class: "w-full rounded-md border border-zinc-700 bg-zinc-950 px-2 py-1.5 text-sm text-white", placeholder: "Correct card name" %>
                <div class="flex gap-2">
                  <%= form.submit "Resolve", class: "rounded-md bg-emerald-600 px-3 py-1.5 text-sm font-medium text-white hover:bg-emerald-500" %>
                  <%= form.submit "Ignore", class: "rounded-md border border-zinc-700 px-3 py-1.5 text-sm font-medium text-zinc-200 hover:bg-zinc-800" %>
                </div>
              <% end %>
            <% end %>
          </li>
        <% end %>
      </ul>
    </div>
  <% end %>
</section>
