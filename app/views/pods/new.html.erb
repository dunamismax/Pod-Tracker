<% content_for :title, "Build a pod" %>

<section class="mx-auto w-full max-w-3xl space-y-6">
  <div>
    <h1 class="text-2xl font-semibold text-white">Build a pod</h1>
    <p class="mt-1 text-sm text-zinc-400">
      Pick 2–4 decks. Pod Tracker will run deterministic analysis on each (if it hasn't yet), then surface score spread, table-warnings, and a Rule 0 brief.
    </p>
  </div>

  <% if @decks.empty? %>
    <div class="rounded-md border border-amber-800 bg-amber-950/40 p-4 text-sm text-amber-200">
      Import at least one deck of your own before you can build a pod. <%= link_to "Import a deck", new_deck_path, class: "underline" %> first. You can add a guest deck below for the remaining slot once you do.
    </div>
  <% else %>
    <%= form_with model: @form, url: pods_path, scope: :pod_form, local: true, class: "space-y-5", data: { offline_disable: true } do |form| %>
      <% if @form.errors.any? %>
        <div class="rounded-md border border-red-800 bg-red-950/40 p-3 text-sm text-red-200">
          <ul class="list-disc pl-5">
            <% @form.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div>
        <%= form.label :name, "Pod name", class: "block text-sm font-medium text-zinc-300" %>
        <%= form.text_field :name, class: "mt-1 block w-full rounded-md border border-zinc-700 bg-zinc-900 px-3 py-2 text-zinc-100", placeholder: "Friday night kitchen-table" %>
      </div>

      <fieldset class="space-y-2">
        <legend class="text-sm font-medium text-zinc-300">Decks (<%= Pod::MIN_SLOTS %>–<%= Pod::MAX_SLOTS %>)</legend>
        <p class="text-xs text-zinc-500">
          Pick the decks heading to the table. Add an optional player or seat label for the Rule 0 brief.
        </p>
        <ul class="space-y-2">
          <% @decks.each do |deck| %>
            <li class="flex flex-wrap items-center gap-3 rounded-md border border-zinc-800 bg-zinc-900 px-3 py-2">
              <label class="flex items-center gap-2 text-sm text-zinc-100">
                <%= check_box_tag "pod_form[deck_ids][]", deck.id, Array(@form.deck_ids).map(&:to_s).include?(deck.id.to_s),
                                  class: "h-4 w-4 rounded border-zinc-600 bg-zinc-800 text-emerald-500" %>
                <span class="font-medium"><%= deck.name %></span>
                <span class="text-xs text-zinc-500"><%= deck.commander_names.join(", ") %></span>
              </label>
              <%= text_field_tag "pod_form[slot_labels][#{deck.id}]", @form.slot_label_for(deck.id),
                                 placeholder: "Player or seat (optional)",
                                 autocomplete: "off",
                                 class: "ml-auto w-48 rounded-md border border-zinc-700 bg-zinc-950 px-2 py-1 text-xs text-zinc-100" %>
            </li>
          <% end %>
        </ul>
      </fieldset>

      <fieldset class="space-y-3 rounded-md border border-zinc-800 bg-zinc-950/50 p-4">
        <legend class="px-1 text-sm font-medium text-zinc-300">Guest deck (optional)</legend>
        <p class="text-xs text-zinc-500">
          Add one deck that's not in your library by pasting a decklist or providing a public Archidekt or Moxfield URL.
          The guest deck is analyzed once for this pod and removed when the pod is removed.
        </p>

        <div class="grid gap-3 sm:grid-cols-2">
          <div>
            <label for="pod_form_guest_deck_name" class="block text-xs font-medium text-zinc-400">Deck name (optional)</label>
            <%= text_field_tag "pod_form[guest_deck][name]", @form.guest_name,
                               id: "pod_form_guest_deck_name",
                               placeholder: "e.g. Voja Friends",
                               autocomplete: "off",
                               class: "mt-1 block w-full rounded-md border border-zinc-700 bg-zinc-900 px-3 py-2 text-sm text-zinc-100" %>
          </div>
          <div>
            <label for="pod_form_guest_deck_label" class="block text-xs font-medium text-zinc-400">Player or seat (optional)</label>
            <%= text_field_tag "pod_form[guest_deck][label]", @form.guest_label,
                               id: "pod_form_guest_deck_label",
                               placeholder: "e.g. Mara · seat 4",
                               autocomplete: "off",
                               class: "mt-1 block w-full rounded-md border border-zinc-700 bg-zinc-900 px-3 py-2 text-sm text-zinc-100" %>
          </div>
        </div>

        <div>
          <label for="pod_form_guest_deck_decklist" class="block text-xs font-medium text-zinc-400">Paste a decklist</label>
          <%= text_area_tag "pod_form[guest_deck][decklist]", @form.guest_decklist,
                            id: "pod_form_guest_deck_decklist",
                            rows: 6,
                            placeholder: "1 Sol Ring\n1 Command Tower\n…",
                            class: "mt-1 block w-full rounded-md border border-zinc-700 bg-zinc-900 px-3 py-2 font-mono text-xs text-zinc-100" %>
        </div>

        <div class="grid gap-3 sm:grid-cols-2">
          <div>
            <label for="pod_form_guest_deck_archidekt_url" class="block text-xs font-medium text-zinc-400">…or Archidekt URL</label>
            <%= text_field_tag "pod_form[guest_deck][archidekt_url]", @form.guest_archidekt_url,
                               id: "pod_form_guest_deck_archidekt_url",
                               placeholder: "https://archidekt.com/decks/…",
                               autocomplete: "off",
                               class: "mt-1 block w-full rounded-md border border-zinc-700 bg-zinc-900 px-3 py-2 text-sm text-zinc-100" %>
          </div>
          <div>
            <label for="pod_form_guest_deck_moxfield_url" class="block text-xs font-medium text-zinc-400">…or Moxfield URL</label>
            <%= text_field_tag "pod_form[guest_deck][moxfield_url]", @form.guest_moxfield_url,
                               id: "pod_form_guest_deck_moxfield_url",
                               placeholder: "https://moxfield.com/decks/…",
                               autocomplete: "off",
                               class: "mt-1 block w-full rounded-md border border-zinc-700 bg-zinc-900 px-3 py-2 text-sm text-zinc-100" %>
          </div>
        </div>
        <p class="text-xs text-zinc-500">Use only one source per guest deck.</p>
      </fieldset>

      <div class="flex flex-wrap gap-3">
        <%= form.submit "Analyze pod", class: "rounded-md bg-emerald-600 px-3.5 py-2.5 text-sm font-medium text-white hover:bg-emerald-500" %>
        <%= link_to "Cancel", pods_path, class: "rounded-md bg-zinc-800 px-3.5 py-2.5 text-sm font-medium text-white hover:bg-zinc-700" %>
      </div>
    <% end %>
  <% end %>
</section>
