<%
  evaluation ||= nil
  raise "pod ai_analysis partial requires evaluation" if evaluation.nil?

  axis_specs = [
    { key: "power", label: "Power" },
    { key: "speed", label: "Speed" },
    { key: "interaction", label: "Interaction" },
    { key: "consistency", label: "Consistency" },
    { key: "salt", label: "Salt" },
    { key: "social_friction", label: "Social friction" }
  ]
  spread = evaluation.bracket_spread
  brief = evaluation.rule_zero_brief
%>

<section class="space-y-4" data-testid="ai-pod-analysis">
  <header class="flex flex-wrap items-baseline justify-between gap-3">
    <div>
      <h2 class="text-lg font-medium text-white">AI pod evaluation</h2>
      <p class="mt-1 text-xs text-zinc-500">
        Evaluated by Codex against the official Commander Brackets, Game Changers list, current Commander banlist, and this pod's full decklists.
        <% if evaluation.prompt_version.present? %>
          · Prompt <code class="font-mono"><%= evaluation.prompt_version %></code>
        <% end %>
        <% if evaluation.model.present? %>
          · Model <code class="font-mono"><%= evaluation.model %></code>
        <% end %>
        <% if evaluation.completed_at.present? %>
          · Completed <%= time_ago_in_words(evaluation.completed_at) %> ago
        <% end %>
        <% if evaluation.stale? %>
          · <span class="text-amber-300">Stale after deterministic pod changes</span>
        <% end %>
      </p>
    </div>
  </header>

  <article class="rounded-lg border border-blue-800 bg-blue-950/30 p-5">
    <header class="flex flex-wrap items-baseline justify-between gap-3">
      <div>
        <p class="text-xs uppercase tracking-wide text-blue-200">Pod bracket spread · AI table read</p>
        <h3 class="mt-1 text-2xl font-semibold text-white"><%= spread["headline"] %></h3>
        <p class="mt-1 text-sm text-blue-100"><%= spread["verdict"] %></p>
      </div>
      <div class="text-right text-sm">
        <p class="text-xs uppercase tracking-wide text-blue-200">Spread</p>
        <p class="mt-1 font-mono text-base text-white">
          <% if spread["min"].present? && spread["max"].present? %>
            B<%= spread["min"] %>-B<%= spread["max"] %>
          <% else %>
            Unknown
          <% end %>
        </p>
        <% if spread["game_changer_total"].present? %>
          <p class="mt-1 text-xs text-blue-100/80"><%= pluralize(spread["game_changer_total"], "Game Changer") %></p>
        <% end %>
      </div>
    </header>

    <% if evaluation.summary.present? %>
      <p class="mt-4 text-sm leading-relaxed text-zinc-100"><%= evaluation.summary %></p>
    <% end %>
    <% if spread["rationale"].present? %>
      <p class="mt-3 text-sm text-blue-100/90"><%= spread["rationale"] %></p>
    <% end %>
    <% if Array(spread["evidence"]).any? %>
      <ul class="mt-4 space-y-1 text-sm text-blue-100/90">
        <% Array(spread["evidence"]).each do |line| %>
          <li class="flex gap-2"><span class="text-blue-300/70">·</span><span><%= line %></span></li>
        <% end %>
      </ul>
    <% end %>
  </article>

  <article class="rounded-lg border border-zinc-800 bg-zinc-900 p-5">
    <h3 class="text-lg font-medium text-white">Rule 0 brief</h3>
    <% if brief["headline"].present? %>
      <p class="mt-1 text-sm text-emerald-300"><%= brief["headline"] %></p>
    <% end %>
    <% if brief["pregame_template"].present? %>
      <div class="mt-4 rounded border border-zinc-800 bg-zinc-950 p-3">
        <p class="text-xs uppercase tracking-wide text-zinc-500">Pregame template</p>
        <pre class="mt-1 whitespace-pre-wrap font-mono text-xs text-zinc-100"><%= brief["pregame_template"] %></pre>
      </div>
    <% end %>
    <% if Array(brief["talking_points"]).any? || Array(brief["disclosures"]).any? %>
      <div class="mt-4 grid gap-4 lg:grid-cols-2">
        <% if Array(brief["talking_points"]).any? %>
          <div>
            <h4 class="text-sm font-medium text-white">Talking points</h4>
            <ul class="mt-2 space-y-2 text-sm">
              <% Array(brief["talking_points"]).each do |point| %>
                <li class="rounded-md border border-zinc-800 bg-zinc-950 p-3">
                  <p class="font-medium text-zinc-100"><%= point["topic"] %></p>
                  <p class="mt-1 text-xs text-zinc-400"><%= point["prompt"] %></p>
                </li>
              <% end %>
            </ul>
          </div>
        <% end %>
        <% if Array(brief["disclosures"]).any? %>
          <div>
            <h4 class="text-sm font-medium text-white">Disclosures</h4>
            <ul class="mt-2 space-y-2 text-sm">
              <% Array(brief["disclosures"]).each do |item| %>
                <li class="rounded-md border border-zinc-800 bg-zinc-950 p-3">
                  <p class="font-medium text-zinc-100"><%= item["label"] %> <span class="text-xs text-zinc-500">· <%= item["severity"] %></span></p>
                  <p class="mt-1 text-xs text-zinc-400"><%= item["detail"] %></p>
                </li>
              <% end %>
            </ul>
          </div>
        <% end %>
      </div>
    <% end %>
  </article>

  <div class="grid gap-4 lg:grid-cols-2">
    <article class="rounded-lg border border-zinc-800 bg-zinc-900 p-5">
      <h3 class="text-lg font-medium text-white">Pod axes</h3>
      <ul class="mt-3 grid gap-2 sm:grid-cols-2">
        <% axis_specs.each do |spec| %>
          <% axis = evaluation.axis(spec[:key]) %>
          <li class="rounded-md border border-zinc-800 bg-zinc-950 p-3">
            <div class="flex items-baseline justify-between gap-3">
              <p class="text-xs uppercase tracking-wide text-zinc-500"><%= spec[:label] %></p>
              <p class="font-mono text-lg text-white"><%= axis["value"] || "—" %><span class="text-xs text-zinc-500">/10</span></p>
            </div>
            <p class="mt-1 text-xs text-zinc-400"><%= axis["rationale"] %></p>
          </li>
        <% end %>
      </ul>
    </article>

    <article class="rounded-lg border border-zinc-800 bg-zinc-900 p-5">
      <h3 class="text-lg font-medium text-white">Per-deck table roles</h3>
      <ul class="mt-3 space-y-2 text-sm">
        <% evaluation.decks.each do |deck| %>
          <li class="rounded-md border border-zinc-800 bg-zinc-950 p-3">
            <div class="flex flex-wrap items-baseline justify-between gap-2">
              <p class="font-medium text-zinc-100"><%= deck["deck_name"] %></p>
              <p class="font-mono text-xs text-zinc-400">B<%= deck["bracket"] %> · <%= deck["sub_band"] %></p>
            </div>
            <p class="mt-1 text-xs text-emerald-300"><%= deck["table_role"] %></p>
            <p class="mt-1 text-xs text-zinc-400"><%= deck["rationale"] %></p>
          </li>
        <% end %>
      </ul>
    </article>
  </div>

  <% if evaluation.friction_drivers.any? || evaluation.recommendations.any? %>
    <div class="grid gap-4 lg:grid-cols-2">
      <% if evaluation.friction_drivers.any? %>
        <article class="rounded-lg border border-zinc-800 bg-zinc-900 p-5">
          <h3 class="text-sm font-medium text-white">Friction drivers</h3>
          <ul class="mt-2 space-y-2 text-sm">
            <% evaluation.friction_drivers.each do |driver| %>
              <li>
                <p class="font-medium text-zinc-100"><%= driver["label"] %> <span class="text-xs text-zinc-500">· <%= driver["severity"] %></span></p>
                <p class="text-xs text-zinc-400"><%= driver["explanation"] %></p>
              </li>
            <% end %>
          </ul>
        </article>
      <% end %>
      <% if evaluation.recommendations.any? %>
        <article class="rounded-lg border border-zinc-800 bg-zinc-900 p-5">
          <h3 class="text-sm font-medium text-white">AI recommendations</h3>
          <ul class="mt-2 space-y-2 text-sm">
            <% evaluation.recommendations.each do |rec| %>
              <li>
                <p class="font-medium text-zinc-100"><%= rec["title"] %></p>
                <p class="text-xs text-zinc-400"><%= rec["detail"] %></p>
              </li>
            <% end %>
          </ul>
        </article>
      <% end %>
    </div>
  <% end %>
</section>
