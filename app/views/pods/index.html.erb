<% content_for :title, "Pods" %>

<section class="space-y-6">
  <div class="flex flex-wrap items-end justify-between gap-4">
    <div>
      <h1 class="text-2xl font-semibold text-white">Your pods</h1>
      <p class="mt-1 text-sm text-zinc-400">
        Compare 2–4 of your decks before a game. Each pod analysis surfaces score spread, archenemy / pubstomp / durdle warnings, and a Rule 0 brief.
      </p>
    </div>
    <%= link_to "Build a pod", new_pod_path, class: "rounded-md bg-emerald-600 px-3.5 py-2.5 text-sm font-medium text-white hover:bg-emerald-500" %>
  </div>

  <% if @pods.empty? %>
    <div class="rounded-lg border border-dashed border-zinc-800 bg-zinc-950 p-8 text-center">
      <p class="text-sm text-zinc-400">No pods yet. Build a pod from your decks to see how they compare.</p>
    </div>
  <% else %>
    <ul class="divide-y divide-zinc-800 overflow-hidden rounded-lg border border-zinc-800 bg-zinc-900">
      <% @pods.each do |pod| %>
        <li class="px-5 py-4">
          <div class="flex flex-wrap items-baseline justify-between gap-4">
            <div>
              <%= link_to pod.name, pod_path(pod), class: "text-base font-medium text-emerald-300 hover:text-emerald-200" %>
              <p class="mt-1 text-xs text-zinc-500">
                <%= pluralize(pod.pod_slots.size, "deck") %>
                <% latest = pod.pod_analysis_runs.last %>
                <% if latest&.completed_at %>
                  · Analyzed <%= time_ago_in_words(latest.completed_at) %> ago
                <% end %>
                <% if pod.shared? %>
                  · Shared
                <% end %>
              </p>
            </div>
            <span class="text-xs uppercase tracking-wide text-zinc-500"><%= pod.status %></span>
          </div>
        </li>
      <% end %>
    </ul>
  <% end %>
</section>
