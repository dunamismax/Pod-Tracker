<%
  pod ||= nil
  snapshot ||= {}
  brief ||= {}
  warnings ||= []
  suggestions ||= []
  read_only = local_assigns.fetch(:read_only, false)

  slots = Array(snapshot["slots"])
  aggregates = snapshot["aggregates"] || {}

  axes = [
    { key: "power", label: "Power" },
    { key: "speed", label: "Speed" },
    { key: "interaction", label: "Interaction" },
    { key: "consistency", label: "Consistency" },
    { key: "salt", label: "Salt" },
    { key: "social_friction", label: "Social friction" }
  ]
%>

<section class="space-y-6 print:space-y-3" data-testid="pod-analysis">
  <% if brief.any? %>
    <article class="rounded-lg border border-zinc-800 bg-zinc-900 p-5 print:border-zinc-300 print:bg-white print:text-zinc-900">
      <header class="flex flex-wrap items-baseline justify-between gap-3">
        <div>
          <h2 class="text-lg font-medium text-white print:text-zinc-900">Rule 0 brief</h2>
          <% br = brief["bracket"] || {} %>
          <% if br["label"].present? %>
            <p class="mt-1 text-base font-semibold text-emerald-300 print:text-emerald-700">
              <%= br["label"] %>
            </p>
            <p class="mt-1 text-sm text-zinc-300 print:text-zinc-700">
              <%= br["summary"] %>
            </p>
            <% if br["game_changers"].present? %>
              <p class="mt-1 text-xs text-zinc-400 print:text-zinc-600">
                <%= br["game_changers"] %>
              </p>
            <% end %>
          <% end %>
          <% pb = brief["power_band"] || {} %>
          <% if pb["label"].present? %>
            <p class="mt-2 text-xs text-zinc-500 print:text-zinc-600">
              Sub-band: <%= pb["label"] %> · <%= pb["summary"] %>
            </p>
          <% end %>
        </div>
      </header>

      <% if brief["pregame_template"].present? %>
        <div class="mt-4 rounded border border-zinc-800/60 bg-zinc-950/40 p-3 print:border-zinc-300 print:bg-zinc-50">
          <p class="text-xs uppercase tracking-wide text-zinc-500">Pregame template (paste into chat)</p>
          <pre class="mt-1 whitespace-pre-wrap font-mono text-xs text-zinc-100 print:text-zinc-900"><%= brief["pregame_template"] %></pre>
        </div>
      <% end %>

      <dl class="mt-4 grid gap-3 text-sm sm:grid-cols-2">
        <% if brief.dig("speed", "summary").present? %>
          <div>
            <dt class="text-xs uppercase tracking-wide text-zinc-500">Tempo</dt>
            <dd class="mt-1 text-zinc-200 print:text-zinc-800"><%= brief["speed"]["summary"] %></dd>
          </div>
        <% end %>
        <% if brief.dig("interaction", "summary").present? %>
          <div>
            <dt class="text-xs uppercase tracking-wide text-zinc-500">Interaction</dt>
            <dd class="mt-1 text-zinc-200 print:text-zinc-800"><%= brief["interaction"]["summary"] %></dd>
          </div>
        <% end %>
      </dl>

      <% combo_notes = Array(brief["combo_stax_notes"]) %>
      <% if combo_notes.any? %>
        <div class="mt-4">
          <p class="text-xs uppercase tracking-wide text-zinc-500">Combo / stax disclosure</p>
          <ul class="mt-1 list-disc pl-5 text-sm text-zinc-200 print:text-zinc-800">
            <% combo_notes.each do |note| %>
              <li><%= note %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <% salt_notes = Array(brief["salt_notes"]) %>
      <% if salt_notes.any? %>
        <div class="mt-4">
          <p class="text-xs uppercase tracking-wide text-zinc-500">Salt drivers</p>
          <ul class="mt-1 list-disc pl-5 text-sm text-zinc-200 print:text-zinc-800">
            <% salt_notes.each do |note| %>
              <li><%= note %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <% friction_notes = Array(brief["friction_notes"]) %>
      <% if friction_notes.any? %>
        <div class="mt-4">
          <p class="text-xs uppercase tracking-wide text-zinc-500">Social friction</p>
          <ul class="mt-1 list-disc pl-5 text-sm text-zinc-200 print:text-zinc-800">
            <% friction_notes.each do |note| %>
              <li><%= note %></li>
            <% end %>
          </ul>
        </div>
      <% end %>
    </article>
  <% end %>

  <% if warnings.any? %>
    <article class="rounded-lg border border-amber-800 bg-amber-950/40 p-5 print:border-amber-400 print:bg-amber-50">
      <h2 class="text-sm font-medium uppercase tracking-wide text-amber-200 print:text-amber-900">Table warnings</h2>
      <ul class="mt-3 space-y-2 text-sm">
        <% warnings.each do |w| %>
          <li class="flex flex-col gap-1">
            <p class="text-amber-100 print:text-amber-900">
              <span class="font-mono text-xs uppercase text-amber-300 print:text-amber-700"><%= w["severity"] %></span>
              <%= w["message"] %>
            </p>
            <% if Array(w["decks"]).any? %>
              <p class="text-xs text-amber-200/80 print:text-amber-800">
                Decks: <%= Array(w["decks"]).map { |d| d["deck_name"] }.join(", ") %>
              </p>
            <% end %>
          </li>
        <% end %>
      </ul>
    </article>
  <% end %>

  <% if slots.any? %>
    <article class="rounded-lg border border-zinc-800 bg-zinc-900 p-5 print:border-zinc-300 print:bg-white">
      <h2 class="text-lg font-medium text-white print:text-zinc-900">Per-deck scores</h2>
      <div class="mt-3 overflow-x-auto">
        <table class="min-w-full divide-y divide-zinc-800 text-sm print:divide-zinc-300">
          <thead class="text-left text-xs uppercase tracking-wide text-zinc-500">
            <tr>
              <th class="py-2 pr-4">Deck</th>
              <th class="py-2 pr-3 text-right">Bracket</th>
              <% axes.each do |axis| %>
                <th class="py-2 pr-3 text-right"><%= axis[:label] %></th>
              <% end %>
            </tr>
          </thead>
          <tbody class="divide-y divide-zinc-800 print:divide-zinc-300">
            <% slots.each do |slot| %>
              <% scores = slot["scores"] || {} %>
              <% bp = slot["bracket_payload"] || {} %>
              <tr>
                <td class="py-2 pr-4">
                  <p class="font-medium text-zinc-100 print:text-zinc-900"><%= slot["deck_name"] %></p>
                  <p class="text-xs text-zinc-500"><%= Array(slot["commander_names"]).join(", ") %></p>
                  <% if slot["label"].present? %>
                    <p class="text-xs text-emerald-400 print:text-emerald-700"><%= slot["label"] %></p>
                  <% end %>
                </td>
                <td class="py-2 pr-3 text-right">
                  <% if slot["bracket"].present? %>
                    <p class="font-mono text-base text-zinc-100 print:text-zinc-900">B<%= slot["bracket"] %></p>
                    <p class="text-xs text-zinc-500"><%= bp["label"] %></p>
                    <% if slot["bracket_sub_band"].present? %>
                      <p class="text-xs text-zinc-500"><%= slot["bracket_sub_band"] %>-band</p>
                    <% end %>
                  <% else %>
                    <p class="text-xs text-zinc-500">—</p>
                  <% end %>
                </td>
                <% axes.each do |axis| %>
                  <td class="py-2 pr-3 text-right text-zinc-200 print:text-zinc-800">
                    <%= scores[axis[:key]] || "—" %>
                  </td>
                <% end %>
              </tr>
            <% end %>
            <% bracket_summary = snapshot["bracket"] || {} %>
            <tr class="bg-zinc-950/40 print:bg-zinc-100">
              <td class="py-2 pr-4 text-xs uppercase tracking-wide text-zinc-500">Spread (max − min)</td>
              <td class="py-2 pr-3 text-right text-zinc-300 print:text-zinc-800">
                <%= bracket_summary["spread"] || "—" %>
              </td>
              <% axes.each do |axis| %>
                <% agg = aggregates[axis[:key]] || {} %>
                <td class="py-2 pr-3 text-right text-zinc-300 print:text-zinc-800">
                  <%= agg["spread"] || "—" %>
                </td>
              <% end %>
            </tr>
            <tr class="bg-zinc-950/40 print:bg-zinc-100">
              <td class="py-2 pr-4 text-xs uppercase tracking-wide text-zinc-500">Pod average</td>
              <td class="py-2 pr-3 text-right text-zinc-300 print:text-zinc-800">
                <%= bracket_summary["min"].present? && bracket_summary["max"].present? ? "B#{bracket_summary['min']}–B#{bracket_summary['max']}" : "—" %>
              </td>
              <% axes.each do |axis| %>
                <% agg = aggregates[axis[:key]] || {} %>
                <td class="py-2 pr-3 text-right text-zinc-300 print:text-zinc-800">
                  <%= agg["average"] || "—" %>
                </td>
              <% end %>
            </tr>
          </tbody>
        </table>
      </div>
    </article>
  <% end %>

  <% if suggestions.any? %>
    <article class="rounded-lg border border-zinc-800 bg-zinc-900 p-5 print:border-zinc-300 print:bg-white">
      <h2 class="text-lg font-medium text-white print:text-zinc-900">Suggested swaps</h2>
      <ul class="mt-3 space-y-3 text-sm">
        <% suggestions.each do |suggestion| %>
          <li>
            <p class="font-medium text-zinc-100 print:text-zinc-900">
              <%= suggestion["title"] %>
              <span class="text-xs text-zinc-500">— <%= suggestion["deck_name"] %></span>
            </p>
            <p class="text-xs text-zinc-400 print:text-zinc-700"><%= suggestion["detail"] %></p>
          </li>
        <% end %>
      </ul>
    </article>
  <% end %>
</section>
