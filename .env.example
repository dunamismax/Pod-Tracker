RAILS_ENV=development
RAILS_MAX_THREADS=5

# Local development can use the default PostgreSQL socket/user from config/database.yml.
# DATABASE_URL=postgres://ideal_magic:password@localhost:5432/ideal_magic_development

# Required in production.
RAILS_MASTER_KEY=
ACTIVE_RECORD_ENCRYPTION_PRIMARY_KEY=
ACTIVE_RECORD_ENCRYPTION_DETERMINISTIC_KEY=
ACTIVE_RECORD_ENCRYPTION_KEY_DERIVATION_SALT=
IDEAL_MAGIC_DATABASE_PASSWORD=

# Optional future Codex runtime wiring. Do not commit Codex auth caches or tokens.
CODEX_APP_SERVER_ENABLED=false
# Per-user CODEX_HOME directories live under this root. Each Ideal Magic user
# gets their own isolated subdirectory <CODEX_HOME_ROOT>/<user.id>/ owned by
# the service user, mode 0700. Defaults to tmp/codex_home in development.
CODEX_HOME_ROOT=
CODEX_APP_SERVER_COMMAND=
# Per-request timeout for non-streaming JSON-RPC calls (auth, account reads).
CODEX_APP_SERVER_REQUEST_TIMEOUT_SECONDS=20
# Wall-clock cap for a single streaming turn. AI evaluations stream
# notifications for the full duration of model output, so this needs to be
# large; it is the longest a single deck/pod evaluation is allowed to take.
CODEX_APP_SERVER_STREAM_TIMEOUT_SECONDS=600
# Maximum quiet gap between streamed messages before the transport is
# considered stuck. Bound by the wall-clock cap above.
CODEX_APP_SERVER_STREAM_IDLE_TIMEOUT_SECONDS=60
