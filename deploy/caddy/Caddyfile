pod-tracker.app {
	encode zstd gzip

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
	}

	# Rust web service, matching POD_TRACKER_ADDR in production.env.example.
	# Rollback keeps this port stable and moves /opt/pod-tracker/current to
	# the previous verified release before restarting pod-tracker-web.service.
	reverse_proxy 127.0.0.1:8083
}

www.pod-tracker.app {
	redir https://pod-tracker.app{uri} permanent
}
