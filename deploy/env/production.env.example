POD_TRACKER_ADDR=127.0.0.1:8083
POD_TRACKER_ENV=production
POD_TRACKER_TEMPLATE_DIR=web/templates
POD_TRACKER_STATIC_DIR=web/static

# Runtime role. Keep this less privileged than the migration role.
POD_TRACKER_DATABASE_URL=postgres://pod_tracker:CHANGE_ME@127.0.0.1:5432/pod_tracker?sslmode=disable

# Migration/admin role. Required for extension migrations such as
# pg_stat_statements when the runtime role cannot create extensions.
POD_TRACKER_MIGRATION_DATABASE_URL=postgres://pod_tracker_migrator:CHANGE_ME@127.0.0.1:5432/pod_tracker?sslmode=disable
